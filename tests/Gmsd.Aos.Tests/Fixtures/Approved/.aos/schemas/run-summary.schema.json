{
  "$id": "gmsd:aos:schema:run-summary:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifacts": {
      "additionalProperties": false,
      "properties": {
        "commands": {
          "type": "string"
        },
        "logsRoot": {
          "type": "string"
        },
        "manifest": {
          "type": "string"
        },
        "outputsRoot": {
          "type": "string"
        },
        "packet": {
          "type": "string"
        },
        "result": {
          "type": "string"
        },
        "runMetadata": {
          "type": "string"
        }
      },
      "required": [
        "runMetadata",
        "packet",
        "result",
        "manifest",
        "commands",
        "logsRoot",
        "outputsRoot"
      ],
      "type": "object"
    },
    "exitCode": {
      "type": "integer"
    },
    "finishedAtUtc": {
      "type": [
        "string",
        "null"
      ]
    },
    "runId": {
      "pattern": "^[0-9a-f]{32}$",
      "type": "string"
    },
    "schemaVersion": {
      "const": 1,
      "type": "integer"
    },
    "startedAtUtc": {
      "type": "string"
    },
    "status": {
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "runId",
    "status",
    "startedAtUtc",
    "finishedAtUtc",
    "exitCode",
    "artifacts"
  ],
  "title": "AOS Run Summary (.aos/evidence/runs/\u003Crun-id\u003E/summary.json)",
  "type": "object"
}

