{
  "$id": "gmsd:aos:schema:run-commands:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "items": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "args": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "command": {
            "type": "string"
          },
          "exitCode": {
            "type": "integer"
          },
          "runId": {
            "pattern": "^[0-9a-f]{32}$",
            "type": "string"
          }
        },
        "required": [
          "command",
          "args",
          "exitCode",
          "runId"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "schemaVersion": {
      "const": 1,
      "type": "integer"
    }
  },
  "required": [
    "schemaVersion",
    "items"
  ],
  "title": "AOS Run Commands View (.aos/evidence/runs/\u003Crun-id\u003E/commands.json)",
  "type": "object"
}

