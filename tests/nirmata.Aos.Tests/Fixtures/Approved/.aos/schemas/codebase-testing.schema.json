{
  "$id": "nirmata:aos:schema:codebase-testing:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Test project structure, coverage metrics, and testing frameworks",
  "properties": {
    "configuration": {
      "additionalProperties": false,
      "properties": {
        "collectors": {
          "description": "Data collectors enabled (coverage, diagnostics, etc.)",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "parallelExecution": {
          "description": "Whether tests run in parallel",
          "type": "boolean"
        },
        "runSettings": {
          "description": "Path to .runsettings file",
          "type": "string"
        },
        "targetFrameworks": {
          "description": "Target frameworks for tests",
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "coverage": {
      "additionalProperties": false,
      "properties": {
        "byProject": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "branchCoverage": {
                "maximum": 100,
                "minimum": 0,
                "type": "number"
              },
              "lineCoverage": {
                "maximum": 100,
                "minimum": 0,
                "type": "number"
              },
              "projectName": {
                "type": "string"
              },
              "testCount": {
                "minimum": 0,
                "type": "integer"
              }
            },
            "required": [
              "projectName"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "overall": {
          "additionalProperties": false,
          "properties": {
            "branchCoverage": {
              "description": "Branch coverage percentage",
              "maximum": 100,
              "minimum": 0,
              "type": "number"
            },
            "lineCoverage": {
              "description": "Line coverage percentage",
              "maximum": 100,
              "minimum": 0,
              "type": "number"
            },
            "methodCoverage": {
              "description": "Method coverage percentage",
              "maximum": 100,
              "minimum": 0,
              "type": "number"
            }
          },
          "type": "object"
        },
        "tools": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "configuration": {
                "description": "Path to coverage configuration file",
                "type": "string"
              },
              "name": {
                "description": "Coverage tool name (e.g., \u0027Coverlet\u0027, \u0027dotCover\u0027)",
                "type": "string"
              },
              "version": {
                "type": "string"
              }
            },
            "required": [
              "name"
            ],
            "type": "object"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "frameworks": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "name": {
            "description": "Framework name (e.g., \u0027xUnit\u0027, \u0027NUnit\u0027, \u0027MSTest\u0027)",
            "type": "string"
          },
          "projects": {
            "description": "Projects using this framework",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "type": {
            "description": "Framework purpose",
            "enum": [
              "unit",
              "integration",
              "e2e",
              "performance",
              "mock",
              "assertion"
            ],
            "type": "string"
          },
          "version": {
            "description": "Framework version",
            "type": "string"
          }
        },
        "required": [
          "name"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "patterns": {
      "additionalProperties": false,
      "properties": {
        "fixturePattern": {
          "description": "Test fixture/factory pattern used",
          "type": "string"
        },
        "mockingFramework": {
          "description": "Mocking framework in use",
          "type": "string"
        },
        "testNaming": {
          "description": "Test method naming convention",
          "type": "string"
        },
        "testOrganization": {
          "description": "How tests are organized (e.g., \u0027Arrange-Act-Assert\u0027, \u0027Given-When-Then\u0027)",
          "type": "string"
        }
      },
      "type": "object"
    },
    "schemaVersion": {
      "const": 1,
      "type": "integer"
    },
    "testProjects": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "fileCount": {
            "description": "Number of test files",
            "minimum": 0,
            "type": "integer"
          },
          "framework": {
            "description": "Testing framework used",
            "type": "string"
          },
          "linesOfCode": {
            "description": "Lines of test code",
            "minimum": 0,
            "type": "integer"
          },
          "name": {
            "description": "Test project name",
            "type": "string"
          },
          "path": {
            "description": "Relative path to test project file",
            "type": "string"
          },
          "targetProject": {
            "description": "Project being tested (for unit/integration tests)",
            "type": "string"
          },
          "testCount": {
            "description": "Number of test cases",
            "minimum": 0,
            "type": "integer"
          },
          "type": {
            "description": "Test project type",
            "enum": [
              "unit",
              "integration",
              "e2e",
              "performance",
              "acceptance",
              "contract"
            ],
            "type": "string"
          }
        },
        "required": [
          "name",
          "path",
          "type"
        ],
        "type": "object"
      },
      "type": "array"
    }
  },
  "required": [
    "schemaVersion",
    "testProjects",
    "frameworks"
  ],
  "title": "Codebase Testing (testing.json)",
  "type": "object"
}
