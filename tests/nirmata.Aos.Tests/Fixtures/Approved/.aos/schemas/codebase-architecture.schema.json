{
  "$id": "nirmata:aos:schema:codebase-architecture:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Architectural patterns, layer boundaries, and application entry points",
  "properties": {
    "boundaries": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "fromLayer": {
            "description": "Source layer name",
            "type": "string"
          },
          "name": {
            "description": "Boundary identifier",
            "type": "string"
          },
          "rules": {
            "description": "Enforced architectural rules for this boundary",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "toLayer": {
            "description": "Target layer name",
            "type": "string"
          }
        },
        "required": [
          "name",
          "fromLayer",
          "toLayer"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "entryPoints": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "name": {
            "description": "Entry point name or description",
            "type": "string"
          },
          "path": {
            "description": "File path to the entry point",
            "type": "string"
          },
          "project": {
            "description": "Project containing this entry point",
            "type": "string"
          },
          "type": {
            "description": "Application entry point type",
            "enum": [
              "console",
              "web",
              "api",
              "background",
              "library"
            ],
            "type": "string"
          }
        },
        "required": [
          "type",
          "path"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "layers": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "dependencies": {
            "description": "Names of layers this layer depends on",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "name": {
            "description": "Layer name (e.g., \u0027Presentation\u0027, \u0027Domain\u0027, \u0027Infrastructure\u0027)",
            "type": "string"
          },
          "projects": {
            "description": "List of project names/IDs belonging to this layer",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "responsibility": {
            "description": "Brief description of layer responsibility",
            "type": "string"
          }
        },
        "required": [
          "name",
          "responsibility"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "patterns": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "files": {
            "description": "Key files implementing this pattern",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "implementation": {
            "description": "How the pattern is implemented in this codebase",
            "type": "string"
          },
          "name": {
            "description": "Pattern name (e.g., \u0027Repository\u0027, \u0027CQRS\u0027, \u0027Dependency Injection\u0027)",
            "type": "string"
          },
          "type": {
            "description": "Pattern classification",
            "enum": [
              "creational",
              "structural",
              "behavioral",
              "architectural"
            ],
            "type": "string"
          }
        },
        "required": [
          "name",
          "type"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "schemaVersion": {
      "const": 1,
      "type": "integer"
    }
  },
  "required": [
    "schemaVersion",
    "layers",
    "patterns",
    "entryPoints"
  ],
  "title": "Codebase Architecture (architecture.json)",
  "type": "object"
}
