{
  "$id": "gmsd:aos:schema:codebase-conventions:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Coding conventions, naming patterns, organization rules, and style patterns",
  "properties": {
    "naming": {
      "additionalProperties": false,
      "properties": {
        "files": {
          "additionalProperties": false,
          "properties": {
            "casing": {
              "description": "File naming casing style",
              "enum": [
                "PascalCase",
                "camelCase",
                "kebab-case",
                "snake_case"
              ],
              "type": "string"
            },
            "matchTypeName": {
              "description": "Whether file names match their primary type name",
              "type": "boolean"
            }
          },
          "type": "object"
        },
        "members": {
          "additionalProperties": false,
          "properties": {
            "constants": {
              "description": "Constant naming convention",
              "type": "string"
            },
            "fields": {
              "description": "Field naming convention",
              "type": "string"
            },
            "localVariables": {
              "description": "Local variable naming convention",
              "type": "string"
            },
            "methods": {
              "description": "Method naming convention",
              "type": "string"
            },
            "parameters": {
              "description": "Parameter naming convention",
              "type": "string"
            },
            "properties": {
              "description": "Property naming convention",
              "type": "string"
            }
          },
          "type": "object"
        },
        "namespaces": {
          "additionalProperties": false,
          "properties": {
            "examples": {
              "description": "Example namespaces",
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "pattern": {
              "description": "Namespace naming pattern",
              "type": "string"
            },
            "root": {
              "description": "Root namespace",
              "type": "string"
            }
          },
          "type": "object"
        },
        "projects": {
          "additionalProperties": false,
          "properties": {
            "examples": {
              "description": "Example project names following the convention",
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "pattern": {
              "description": "Project naming pattern (e.g., \u0027PascalCase\u0027, \u0027Company.Product.Feature\u0027)",
              "type": "string"
            },
            "prefix": {
              "description": "Common project prefix if any",
              "type": "string"
            },
            "suffix": {
              "description": "Common project suffix if any",
              "type": "string"
            }
          },
          "type": "object"
        },
        "types": {
          "additionalProperties": false,
          "properties": {
            "classes": {
              "description": "Class naming convention",
              "type": "string"
            },
            "enums": {
              "description": "Enum naming convention",
              "type": "string"
            },
            "exceptions": {
              "description": "Exception naming convention",
              "type": "string"
            },
            "interfaces": {
              "description": "Interface naming convention (e.g., \u0027IPascalCase\u0027)",
              "type": "string"
            },
            "structs": {
              "description": "Struct naming convention",
              "type": "string"
            }
          },
          "type": "object"
        }
      },
      "type": "object"
    },
    "organization": {
      "additionalProperties": false,
      "properties": {
        "filePerType": {
          "description": "Whether each type has its own file",
          "type": "boolean"
        },
        "maxFileLines": {
          "description": "Recommended maximum lines per file",
          "minimum": 1,
          "type": "integer"
        },
        "maxTypeMembers": {
          "description": "Recommended maximum members per type",
          "minimum": 1,
          "type": "integer"
        },
        "namespaceToFolderMapping": {
          "description": "Whether namespaces map to folder structure",
          "type": "boolean"
        },
        "projectStructure": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "contents": {
                "description": "What should be placed here",
                "type": "string"
              },
              "folder": {
                "description": "Standard folder name",
                "type": "string"
              },
              "purpose": {
                "description": "Purpose of this folder",
                "type": "string"
              },
              "required": {
                "description": "Whether this folder is required",
                "type": "boolean"
              }
            },
            "required": [
              "folder",
              "purpose"
            ],
            "type": "object"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "schemaVersion": {
      "const": 1,
      "type": "integer"
    },
    "stylePatterns": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "category": {
            "description": "Pattern category",
            "enum": [
              "formatting",
              "documentation",
              "ordering",
              "accessibility",
              "architecture"
            ],
            "type": "string"
          },
          "description": {
            "description": "Pattern description",
            "type": "string"
          },
          "enforced": {
            "description": "Whether this pattern is enforced",
            "type": "boolean"
          },
          "name": {
            "description": "Style pattern name",
            "type": "string"
          },
          "tooling": {
            "description": "Tools that enforce this pattern",
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "required": [
          "name"
        ],
        "type": "object"
      },
      "type": "array"
    }
  },
  "required": [
    "schemaVersion",
    "naming",
    "organization"
  ],
  "title": "Codebase Conventions (conventions.json)",
  "type": "object"
}
