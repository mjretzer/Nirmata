{
  "$id": "gmsd:aos:schema:agent-result:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "outcome": {
            "const": "failure"
          }
        },
        "required": [
          "outcome"
        ]
      },
      "then": {
        "required": [
          "error"
        ]
      }
    }
  ],
  "properties": {
    "agentId": {
      "minLength": 1,
      "type": "string"
    },
    "error": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "minLength": 1,
          "type": "string"
        },
        "details": {},
        "message": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "code",
        "message"
      ],
      "type": "object"
    },
    "outcome": {
      "enum": [
        "success",
        "failure"
      ],
      "type": "string"
    },
    "output": {
      "additionalProperties": true,
      "type": "object"
    },
    "requestId": {
      "minLength": 1,
      "type": "string"
    },
    "runId": {
      "minLength": 1,
      "type": "string"
    },
    "schemaVersion": {
      "const": 1,
      "type": "integer"
    }
  },
  "required": [
    "schemaVersion",
    "runId",
    "agentId",
    "requestId"
  ],
  "title": "AOS Specialist Agent Result",
  "type": "object"
}
