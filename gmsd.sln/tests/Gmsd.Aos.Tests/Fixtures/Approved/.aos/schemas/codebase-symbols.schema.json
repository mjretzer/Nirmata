{
  "$id": "gmsd:aos:schema:codebase-symbols:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Symbol index cache for fast lookup of types, methods, properties and their locations",
  "properties": {
    "generatedAt": {
      "description": "ISO 8601 timestamp when the symbol cache was generated",
      "format": "date-time",
      "type": "string"
    },
    "locations": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "endColumn": {
            "description": "1-based ending column number",
            "minimum": 1,
            "type": "integer"
          },
          "endLine": {
            "description": "1-based ending line number",
            "minimum": 1,
            "type": "integer"
          },
          "filePath": {
            "description": "Absolute file path",
            "type": "string"
          },
          "startColumn": {
            "description": "1-based starting column number",
            "minimum": 1,
            "type": "integer"
          },
          "startLine": {
            "description": "1-based starting line number",
            "minimum": 1,
            "type": "integer"
          },
          "symbolId": {
            "description": "Reference to symbol id",
            "type": "string"
          }
        },
        "required": [
          "symbolId",
          "filePath",
          "startLine",
          "startColumn"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "references": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "fromSymbolId": {
            "description": "Symbol that makes the reference",
            "type": "string"
          },
          "location": {
            "additionalProperties": false,
            "properties": {
              "column": {
                "minimum": 1,
                "type": "integer"
              },
              "filePath": {
                "type": "string"
              },
              "line": {
                "minimum": 1,
                "type": "integer"
              }
            },
            "required": [
              "filePath",
              "line",
              "column"
            ],
            "type": "object"
          },
          "referenceType": {
            "description": "Type of reference relationship",
            "enum": [
              "invocation",
              "inheritance",
              "implementation",
              "usage",
              "declaration",
              "assignment"
            ],
            "type": "string"
          },
          "toSymbolId": {
            "description": "Symbol being referenced",
            "type": "string"
          }
        },
        "required": [
          "fromSymbolId",
          "toSymbolId"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "schemaVersion": {
      "const": 1,
      "type": "integer"
    },
    "symbols": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "accessibility": {
            "description": "Symbol accessibility modifier",
            "enum": [
              "public",
              "internal",
              "protected",
              "private",
              "protected-internal",
              "private-protected"
            ],
            "type": "string"
          },
          "attributes": {
            "description": "Applied attributes",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "declaringType": {
            "description": "For members, the containing type name",
            "type": "string"
          },
          "documentation": {
            "description": "XML documentation summary if available",
            "type": "string"
          },
          "id": {
            "description": "Unique symbol identifier",
            "type": "string"
          },
          "kind": {
            "description": "Symbol classification",
            "enum": [
              "namespace",
              "class",
              "interface",
              "struct",
              "enum",
              "delegate",
              "method",
              "property",
              "field",
              "event",
              "constructor",
              "operator",
              "indexer",
              "constant"
            ],
            "type": "string"
          },
          "name": {
            "description": "Symbol name",
            "type": "string"
          },
          "namespace": {
            "description": "Containing namespace",
            "type": "string"
          },
          "signature": {
            "description": "Method/property signature for overload resolution",
            "type": "string"
          }
        },
        "required": [
          "id",
          "name",
          "kind",
          "namespace"
        ],
        "type": "object"
      },
      "type": "array"
    }
  },
  "required": [
    "schemaVersion",
    "generatedAt",
    "symbols",
    "locations",
    "references"
  ],
  "title": "Codebase Symbols Cache (cache/symbols.json)",
  "type": "object"
}
