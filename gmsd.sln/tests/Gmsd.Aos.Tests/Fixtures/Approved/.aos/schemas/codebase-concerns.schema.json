{
  "$id": "gmsd:aos:schema:codebase-concerns:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Cross-cutting concerns, hotspots, and complexity indicators",
  "properties": {
    "complexity": {
      "additionalProperties": false,
      "properties": {
        "averageCyclomaticComplexity": {
          "description": "Average cyclomatic complexity across codebase",
          "minimum": 0,
          "type": "number"
        },
        "commentDensity": {
          "description": "Ratio of comment lines to total lines",
          "minimum": 0,
          "type": "number"
        },
        "highComplexityFiles": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "complexity": {
                "description": "Cyclomatic complexity score",
                "minimum": 0,
                "type": "integer"
              },
              "filePath": {
                "description": "Path to high-complexity file",
                "type": "string"
              },
              "methodCount": {
                "description": "Number of methods in file",
                "minimum": 0,
                "type": "integer"
              }
            },
            "required": [
              "filePath",
              "complexity"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "maxCyclomaticComplexity": {
          "description": "Maximum cyclomatic complexity found",
          "minimum": 0,
          "type": "integer"
        },
        "totalLinesOfCode": {
          "description": "Total lines of code in analyzed files",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "averageCyclomaticComplexity",
        "maxCyclomaticComplexity",
        "highComplexityFiles"
      ],
      "type": "object"
    },
    "crossCutting": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "affectedFiles": {
            "description": "Files affected by or using this concern",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "category": {
            "description": "Category of cross-cutting concern",
            "enum": [
              "logging",
              "security",
              "configuration",
              "error-handling",
              "caching",
              "validation",
              "instrumentation",
              "localization",
              "other"
            ],
            "type": "string"
          },
          "description": {
            "description": "Brief description of how this concern is addressed",
            "type": "string"
          },
          "implementationFiles": {
            "description": "Files implementing this cross-cutting concern",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "name": {
            "description": "Concern name (e.g., \u0027Logging\u0027, \u0027Authentication\u0027, \u0027Configuration\u0027)",
            "type": "string"
          }
        },
        "required": [
          "name",
          "category"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "hotspots": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "changeFrequency": {
            "description": "Number of times file has been modified",
            "minimum": 0,
            "type": "integer"
          },
          "contributorCount": {
            "description": "Number of unique contributors to this file",
            "minimum": 0,
            "type": "integer"
          },
          "filePath": {
            "description": "Path to the hotspot file",
            "type": "string"
          },
          "reasoning": {
            "description": "Why this file is considered a hotspot",
            "type": "string"
          },
          "score": {
            "description": "Hotspot score (higher indicates more activity/risk)",
            "minimum": 0,
            "type": "integer"
          }
        },
        "required": [
          "filePath",
          "score"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "schemaVersion": {
      "const": 1,
      "type": "integer"
    }
  },
  "required": [
    "schemaVersion",
    "crossCutting",
    "hotspots",
    "complexity"
  ],
  "title": "Codebase Concerns (concerns.json)",
  "type": "object"
}
