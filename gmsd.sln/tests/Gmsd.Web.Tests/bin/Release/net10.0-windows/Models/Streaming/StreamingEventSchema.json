{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gmsd.local/schemas/streaming-event.json",
  "title": "StreamingEvent",
  "description": "Schema for GMSD streaming dialogue events",
  "type": "object",
  "required": ["id", "type", "timestamp"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for this event",
      "pattern": "^[a-f0-9]{32}$"
    },
    "type": {
      "type": "string",
      "description": "The type of event being emitted",
      "enum": [
        "intentClassified",
        "gateSelected",
        "toolCall",
        "toolResult",
        "phaseLifecycle",
        "assistantDelta",
        "assistantFinal",
        "runLifecycle",
        "error"
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the event was emitted"
    },
    "correlationId": {
      "type": "string",
      "description": "Optional correlation ID for tracing events across a conversation"
    },
    "sequenceNumber": {
      "type": "integer",
      "description": "Optional sequence number for ordering events"
    },
    "payload": {
      "description": "The event payload - varies by event type",
      "oneOf": [
        { "$ref": "#/definitions/IntentClassifiedPayload" },
        { "$ref": "#/definitions/GateSelectedPayload" },
        { "$ref": "#/definitions/ToolCallPayload" },
        { "$ref": "#/definitions/ToolResultPayload" },
        { "$ref": "#/definitions/PhaseLifecyclePayload" },
        { "$ref": "#/definitions/AssistantDeltaPayload" },
        { "$ref": "#/definitions/AssistantFinalPayload" },
        { "$ref": "#/definitions/RunLifecyclePayload" },
        { "$ref": "#/definitions/ErrorPayload" }
      ]
    }
  },
  "definitions": {
    "IntentClassifiedPayload": {
      "type": "object",
      "required": ["category", "confidence"],
      "properties": {
        "category": {
          "type": "string",
          "description": "The classified intent category"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Confidence score between 0.0 and 1.0"
        },
        "reasoning": {
          "type": "string",
          "description": "Reasoning for the classification decision"
        },
        "userInput": {
          "type": "string",
          "description": "The original user input that was classified"
        }
      }
    },
    "GateSelectedPayload": {
      "type": "object",
      "required": ["phase"],
      "properties": {
        "phase": {
          "type": "string",
          "description": "The selected target phase"
        },
        "reasoning": {
          "type": "string",
          "description": "Reasoning for the gating decision"
        },
        "requiresConfirmation": {
          "type": "boolean",
          "description": "Whether this action requires user confirmation"
        },
        "proposedAction": {
          "$ref": "#/definitions/ProposedAction"
        }
      }
    },
    "ProposedAction": {
      "type": "object",
      "required": ["description"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for this proposed action"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of the action"
        },
        "actionType": {
          "type": "string",
          "description": "The type of action being proposed"
        },
        "parameters": {
          "type": "object",
          "description": "Additional context or parameters for the action"
        }
      }
    },
    "ToolCallPayload": {
      "type": "object",
      "required": ["callId", "toolName"],
      "properties": {
        "callId": {
          "type": "string",
          "description": "Unique identifier for correlating call with result"
        },
        "toolName": {
          "type": "string",
          "description": "The name of the tool being invoked"
        },
        "parameters": {
          "type": "object",
          "description": "The parameters passed to the tool"
        },
        "phaseContext": {
          "type": "string",
          "description": "The phase context in which the tool is being called"
        }
      }
    },
    "ToolResultPayload": {
      "type": "object",
      "required": ["callId", "success"],
      "properties": {
        "callId": {
          "type": "string",
          "description": "Unique identifier matching the original tool.call"
        },
        "success": {
          "type": "boolean",
          "description": "Whether the tool execution succeeded"
        },
        "result": {
          "description": "The result data from tool execution"
        },
        "error": {
          "type": "string",
          "description": "Error message if execution failed"
        },
        "durationMs": {
          "type": "integer",
          "description": "Duration of tool execution in milliseconds"
        }
      }
    },
    "PhaseLifecyclePayload": {
      "type": "object",
      "required": ["phase", "status"],
      "properties": {
        "phase": {
          "type": "string",
          "description": "The phase name"
        },
        "status": {
          "type": "string",
          "enum": ["started", "completed"],
          "description": "Whether this is a start or completion event"
        },
        "context": {
          "type": "object",
          "description": "Contextual information about the phase"
        },
        "artifacts": {
          "type": "array",
          "items": { "$ref": "#/definitions/PhaseArtifact" },
          "description": "Output artifacts produced by the phase"
        },
        "error": {
          "$ref": "#/definitions/PhaseError"
        }
      }
    },
    "PhaseArtifact": {
      "type": "object",
      "required": ["type", "name"],
      "properties": {
        "type": {
          "type": "string",
          "description": "The type of artifact"
        },
        "name": {
          "type": "string",
          "description": "Human-readable name of the artifact"
        },
        "reference": {
          "type": "string",
          "description": "Reference to access the artifact"
        },
        "summary": {
          "type": "string",
          "description": "Summary or preview of the artifact content"
        }
      }
    },
    "PhaseError": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "description": "Error code or type"
        },
        "message": {
          "type": "string",
          "description": "Human-readable error message"
        },
        "details": {
          "type": "string",
          "description": "Additional error details or stack trace"
        }
      }
    },
    "AssistantDeltaPayload": {
      "type": "object",
      "required": ["messageId", "content"],
      "properties": {
        "messageId": {
          "type": "string",
          "description": "Unique identifier for the message being streamed"
        },
        "content": {
          "type": "string",
          "description": "The token chunk content"
        },
        "index": {
          "type": "integer",
          "description": "Position in the overall message (0-indexed)"
        }
      }
    },
    "AssistantFinalPayload": {
      "type": "object",
      "required": ["messageId"],
      "properties": {
        "messageId": {
          "type": "string",
          "description": "Unique identifier matching the delta stream"
        },
        "content": {
          "type": "string",
          "description": "The complete final content"
        },
        "structuredData": {
          "description": "Structured data if the response contains rich content"
        },
        "contentType": {
          "type": "string",
          "description": "The content type of the response"
        },
        "isFinal": {
          "type": "boolean",
          "default": true,
          "description": "Whether this response completes a streaming sequence"
        }
      }
    },
    "RunLifecyclePayload": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["started", "finished"],
          "description": "The run status"
        },
        "runId": {
          "type": "string",
          "description": "Unique identifier for the run"
        },
        "durationMs": {
          "type": "integer",
          "description": "Run duration in milliseconds"
        },
        "success": {
          "type": "boolean",
          "description": "Whether the run completed successfully"
        },
        "artifactReferences": {
          "type": "array",
          "items": { "type": "string" },
          "description": "References to artifacts produced by the run"
        }
      }
    },
    "ErrorPayload": {
      "type": "object",
      "required": ["severity", "code", "message"],
      "properties": {
        "severity": {
          "type": "string",
          "enum": ["error", "warning", "info"],
          "description": "Error severity level"
        },
        "code": {
          "type": "string",
          "description": "Error code for categorization"
        },
        "message": {
          "type": "string",
          "description": "Human-readable error message"
        },
        "context": {
          "type": "string",
          "description": "The phase or component where the error occurred"
        },
        "recoverable": {
          "type": "boolean",
          "description": "Whether the error is recoverable"
        },
        "retryAction": {
          "type": "string",
          "description": "Suggested retry action if recoverable"
        }
      }
    }
  }
}
