@page
@model Gmsd.Web.Pages.Projects.IndexModel
@{
    ViewData["Title"] = "Projects";
}

<div class="page-header-actions">
    <h1>Projects</h1>
    <button class="btn btn-primary discuss-btn"
            data-page="projects"
            onclick="handoffPageToChat(this)">
        <span>💬</span> Discuss
    </button>
</div>

@if (Model.Projects.Count == 0)
{
    <div class="empty-state">
        <h3>No Projects Found</h3>
        <p>There are no projects in the system yet.</p>
    </div>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Steps</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var project in Model.Projects)
            {
                <tr>
                    <td>@project.Name</td>
                    <td>@project.Steps.Count</td>
                    <td>
                        <a href="~/Projects/Details/@project.ProjectId">View Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<script>
    function handoffPageToChat(button) {
        const page = button.dataset.page;

        // Dispatch event to load page in detail panel and focus chat
        document.dispatchEvent(new CustomEvent('gmsd:discuss-page', {
            detail: { page }
        }));

        // Also dispatch a toast notification
        document.dispatchEvent(new CustomEvent('gmsd:toast', {
            detail: { message: `Discussing ${page} in chat...`, type: 'info' }
        }));
    }
</script>
