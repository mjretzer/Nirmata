@page "{id}"
@model Gmsd.Web.Pages.Projects.DetailsModel
@{
    ViewData["Title"] = Model.Project?.Name ?? "Project Details";
}

@if (Model.IsNotFound)
{
    <div class="error-message">
        <h2>Project Not Found</h2>
        <p>The requested project could not be found.</p>
    </div>
    <a href="~/Projects" class="btn btn-secondary mt-2">Back to Projects</a>
}
else if (Model.Project != null)
{
    <div class="page-header-actions">
        <h1>@Model.Project.Name</h1>
        <button class="btn btn-primary discuss-btn"
                data-entity-type="project"
                data-entity-id="@Model.Project.ProjectId"
                data-entity-name="@Model.Project.Name"
                onclick="handoffToChat(this)">
            <span>💬</span> Discuss
        </button>
    </div>

    <div class="card">
        <div class="card-header">
            <h2>Project Details</h2>
        </div>
        <div class="card-body">
            <p><strong>Project ID:</strong> @Model.Project.ProjectId</p>
            <p><strong>Name:</strong> @Model.Project.Name</p>
            <p><strong>Steps:</strong> @Model.Project.Steps.Count</p>
        </div>
    </div>

    @if (Model.Project.Steps.Any())
    {
        <h2 class="mt-2">Steps</h2>
        <table class="table">
            <thead>
                <tr>
                    <th>Name</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var step in Model.Project.Steps)
                {
                    <tr>
                        <td>@step.Name</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <a href="~/Projects" class="btn btn-secondary mt-2">Back to Projects</a>

    <script>
        function handoffToChat(button) {
            const entityType = button.dataset.entityType;
            const entityId = button.dataset.entityId;
            const entityName = button.dataset.entityName;

            // Dispatch event to open entity in detail panel and focus chat
            document.dispatchEvent(new CustomEvent('gmsd:discuss-entity', {
                detail: { entityType, entityId, entityName }
            }));

            // Also dispatch a toast notification
            document.dispatchEvent(new CustomEvent('gmsd:toast', {
                detail: { message: `Discussing ${entityName} in chat...`, type: 'info' }
            }));
        }
    </script>
}
