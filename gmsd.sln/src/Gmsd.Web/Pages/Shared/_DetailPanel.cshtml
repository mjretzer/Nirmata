@model Gmsd.Web.Models.DetailPanelViewModel

@{
    var entity = Model.Entity;
    var activeTab = Model.ActiveTab;
}

<div class="detail-panel-content" id="detail-panel-content" 
     hx-get="/api/detailpanel/content" 
     hx-trigger="entity-selected from:body, refresh from:body"
     hx-target="#detail-panel-content"
     hx-swap="outerHTML">
    
    @if (!Model.HasEntity)
    {
        <div class="detail-empty-state" id="detail-empty-state">
            <span class="empty-icon">📋</span>
            <p>Select an item to view details</p>
            <span class="empty-hint">Click any link in chat or sidebar</span>
        </div>
    }
    else
    {
        <div class="detail-entity-header">
            <div class="entity-type-badge">
                <span class="entity-icon">@entity!.GetTypeIcon()</span>
                <span class="entity-type">@entity.Type</span>
            </div>
            <h3 class="entity-name" title="@entity.Id">@entity.Name</h3>
            <span class="entity-status @entity.GetStatusClass()">@entity.Status</span>
            @if (!string.IsNullOrEmpty(entity.FullPageUrl))
            {
                <a href="@entity.FullPageUrl" class="entity-fullpage-link" title="Open full page" aria-label="Open full page view in new tab">
                    <span aria-hidden="true">↗</span>
                </a>
            }
        </div>

        <div class="tabs-container" id="detail-tabs">
            <div class="tabs-header" role="tablist">
                <button class="tab-button @(activeTab == "properties" ? "active" : "")" 
                        data-tab="properties" 
                        role="tab" 
                        aria-selected="@(activeTab == "properties" ? "true" : "false")"
                        aria-controls="tab-properties">
                    <span class="tab-icon">⚙</span>
                    <span class="tab-label">Properties</span>
                </button>
                <button class="tab-button @(activeTab == "evidence" ? "active" : "")" 
                        data-tab="evidence" 
                        role="tab" 
                        aria-selected="@(activeTab == "evidence" ? "true" : "false")"
                        aria-controls="tab-evidence">
                    <span class="tab-icon">📎</span>
                    <span class="tab-label">Evidence</span>
                    @if (entity.Evidence.Any())
                    {
                        <span class="tab-badge">@entity.Evidence.Count</span>
                    }
                </button>
                <button class="tab-button @(activeTab == "raw" ? "active" : "")" 
                        data-tab="raw" 
                        role="tab" 
                        aria-selected="@(activeTab == "raw" ? "true" : "false")"
                        aria-controls="tab-raw">
                    <span class="tab-icon">{}</span>
                    <span class="tab-label">Raw</span>
                </button>
            </div>

            <div class="tabs-content">
                <!-- Properties Tab -->
                <div class="tab-content @(activeTab == "properties" ? "active" : "")" 
                     id="tab-properties" 
                     role="tabpanel"
                     aria-labelledby="tab-properties">
                    @if (entity.Properties.Any())
                    {
                        <dl class="properties-list">
                            @foreach (var prop in entity.Properties)
                            {
                                <div class="property-item">
                                    <dt class="property-key">@prop.Key</dt>
                                    <dd class="property-value @prop.Value.Format">
                                        @if (!string.IsNullOrEmpty(prop.Value.LinkUrl))
                                        {
                                            <a href="@prop.Value.LinkUrl" class="property-link">@prop.Value.Value</a>
                                        }
                                        else if (prop.Value.IsCopyable)
                                        {
                                            <code class="copyable" data-copy="@prop.Value.Value" title="Click to copy">@prop.Value.Value</code>
                                        }
                                        else if (prop.Value.Format == "code")
                                        {
                                            <code>@prop.Value.Value</code>
                                        }
                                        else
                                        {
                                            <span title="@prop.Value.Tooltip">@prop.Value.Value</span>
                                        }
                                    </dd>
                                </div>
                            }
                        </dl>
                    }
                    else
                    {
                        <div class="tab-empty-state">
                            <span class="empty-icon">⚙</span>
                            <p>No properties available</p>
                        </div>
                    }

                    @if (entity.RelatedEntities.Any())
                    {
                        <div class="related-entities">
                            <h4 class="related-title">Related</h4>
                            <ul class="related-list">
                                @foreach (var related in entity.RelatedEntities)
                                {
                                    <li class="related-item" data-entity-type="@related.Type" data-entity-id="@related.Id" tabindex="0" role="button" aria-label="View related @related.Type: @related.Name">
                                        <span class="related-icon" aria-hidden="true">@(related.Type switch
                                        {
                                            "project" => "📁",
                                            "run" => "▶",
                                            "task" => "☐",
                                            "spec" => "📄",
                                            "issue" => "🐛",
                                            _ => "📋"
                                        })</span>
                                        <span class="related-name">@related.Name</span>
                                        <span class="related-relationship">@related.Relationship</span>
                                    </li>
                                }
                            </ul>
                        </div>
                    }
                </div>

                <!-- Evidence Tab -->
                <div class="tab-content @(activeTab == "evidence" ? "active" : "")" 
                     id="tab-evidence" 
                     role="tabpanel"
                     aria-labelledby="tab-evidence">
                    @if (entity.Evidence.Any())
                    {
                        <ul class="evidence-list">
                            @foreach (var evidence in entity.Evidence)
                            {
                                <li class="evidence-item" data-evidence-id="@evidence.Id">
                                    <div class="evidence-header">
                                        <span class="evidence-icon">@evidence.GetTypeIcon()</span>
                                        <span class="evidence-title">@evidence.Title</span>
                                        <span class="evidence-type">@evidence.Type</span>
                                    </div>
                                    @if (!string.IsNullOrEmpty(evidence.Description))
                                    {
                                        <p class="evidence-description">@evidence.Description</p>
                                    }
                                    @if (!string.IsNullOrEmpty(evidence.Content))
                                    {
                                        <div class="evidence-content">
                                            <pre><code>@evidence.Content</code></pre>
                                        </div>
                                    }
                                    @if (!string.IsNullOrEmpty(evidence.FileUrl))
                                    {
                                        <a href="@evidence.FileUrl" class="evidence-link" target="_blank" aria-label="Download evidence file">
                                            <span aria-hidden="true">📥</span> View/Download
                                        </a>
                                    }
                                    <div class="evidence-meta">
                                        @if (!string.IsNullOrEmpty(evidence.Author))
                                        {
                                            <span class="evidence-author">by @evidence.Author</span>
                                        }
                                        <span class="evidence-time">@evidence.CreatedAt.ToString("g")</span>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="tab-empty-state">
                            <span class="empty-icon">📎</span>
                            <p>No evidence attached</p>
                        </div>
                    }
                </div>

                <!-- Raw Tab -->
                <div class="tab-content @(activeTab == "raw" ? "active" : "")" 
                     id="tab-raw" 
                     role="tabpanel"
                     aria-labelledby="tab-raw">
                    <div class="raw-data-container">
                        <div class="raw-actions">
                        <button class="raw-action-btn" data-action="copy" title="Copy to clipboard" aria-label="Copy raw data to clipboard">
                            <span aria-hidden="true">📋</span> Copy
                        </button>
                        <button class="raw-action-btn" data-action="download" title="Download JSON" aria-label="Download raw data as JSON file">
                            <span aria-hidden="true">💾</span> Download
                        </button>
                        </div>
                        <pre class="json-viewer"><code class="language-json" id="raw-json-data">@entity.RawData</code></pre>
                    </div>
                </div>
            </div>
        </div>

        <div class="detail-footer">
            <span class="loaded-at">Loaded @entity.LoadedAt.ToString("HH:mm:ss")</span>
            <button class="refresh-btn" data-action="refresh" title="Refresh entity data" aria-label="Refresh entity data">
                <span aria-hidden="true">↻</span> Refresh
            </button>
        </div>
    }
</div>

<script>
    // Initialize tab switching for this detail panel instance
    (function() {
        const container = document.getElementById('detail-panel-content');
        if (!container) return;

        const tabButtons = container.querySelectorAll('.tab-button');
        const tabContents = container.querySelectorAll('.tab-content');

        tabButtons.forEach(button => {
            button.addEventListener('click', function() {
                const tabName = this.dataset.tab;
                
                // Update button states
                tabButtons.forEach(btn => {
                    btn.classList.remove('active');
                    btn.setAttribute('aria-selected', 'false');
                });
                this.classList.add('active');
                this.setAttribute('aria-selected', 'true');

                // Update content visibility
                tabContents.forEach(content => {
                    content.classList.remove('active');
                });
                const targetContent = container.querySelector(`#tab-${tabName}`);
                if (targetContent) {
                    targetContent.classList.add('active');
                }

                // Save active tab preference
                try {
                    localStorage.setItem('gmsd_detailpanel_tab', tabName);
                } catch (e) {
                    // Ignore storage errors
                }

                // Trigger syntax highlighting for raw tab
                if (tabName === 'raw' && window.Prism) {
                    const codeBlock = container.querySelector('#raw-json-data');
                    if (codeBlock) {
                        Prism.highlightElement(codeBlock);
                    }
                }
            });
        });

        // Restore last active tab
        try {
            const savedTab = localStorage.getItem('gmsd_detailpanel_tab');
            if (savedTab && savedTab !== '@activeTab') {
                const savedTabButton = container.querySelector(`[data-tab="${savedTab}"]`);
                if (savedTabButton && !savedTabButton.classList.contains('active')) {
                    savedTabButton.click();
                }
            }
        } catch (e) {
            // Ignore storage errors
        }

        // Copy buttons for copyable properties
        container.querySelectorAll('.property-value .copyable').forEach(el => {
            el.addEventListener('click', function() {
                const text = this.dataset.copy || this.textContent;
                navigator.clipboard.writeText(text).then(() => {
                    // Visual feedback
                    const original = this.textContent;
                    this.textContent = 'Copied!';
                    setTimeout(() => {
                        this.textContent = original;
                    }, 1000);
                });
            });
        });

        // Raw tab actions
        const rawCopyBtn = container.querySelector('[data-action="copy"]');
        if (rawCopyBtn) {
            rawCopyBtn.addEventListener('click', function() {
                const rawData = container.querySelector('#raw-json-data')?.textContent;
                if (rawData) {
                    navigator.clipboard.writeText(rawData).then(() => {
                        this.innerHTML = '<span>✓</span> Copied!';
                        setTimeout(() => {
                            this.innerHTML = '<span>📋</span> Copy';
                        }, 2000);
                    });
                }
            });
        }

        const rawDownloadBtn = container.querySelector('[data-action="download"]');
        if (rawDownloadBtn) {
            rawDownloadBtn.addEventListener('click', function() {
                const rawData = container.querySelector('#raw-json-data')?.textContent;
                const entityName = container.querySelector('.entity-name')?.textContent || 'entity';
                if (rawData) {
                    const blob = new Blob([rawData], { type: 'application/json' });
                    const url = URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = `${entityName.ToLowerInvariant().replace(' ', '-')}.json`;
                    document.body.appendChild(a);
                    a.click();
                    document.body.removeChild(a);
                    URL.revokeObjectURL(url);
                }
            });
        }

        // Related entity click handlers
        container.querySelectorAll('.related-item').forEach(item => {
            item.addEventListener('click', function() {
                const entityType = this.dataset.entityType;
                const entityId = this.dataset.entityId;
                if (entityType && entityId && window.DetailPanel) {
                    window.DetailPanel.showEntity(entityType, entityId);
                }
            });
        });

        // Refresh button
        const refreshBtn = container.querySelector('[data-action="refresh"]');
        if (refreshBtn) {
            refreshBtn.addEventListener('click', function() {
                const entity = document.querySelector('.detail-entity-header');
                if (entity && window.DetailPanel) {
                    window.DetailPanel.refresh();
                }
            });
        }

        // Highlight JSON on load if raw tab is active
        if ('@activeTab' === 'raw' && window.Prism) {
            const codeBlock = container.querySelector('#raw-json-data');
            if (codeBlock) {
                Prism.highlightElement(codeBlock);
            }
        }
    })();
</script>
