@model Gmsd.Web.Models.ChatThreadModel

@{
    var threadId = Model.Id;
    var containerId = $"chat-thread-{threadId}";
}

<div class="chat-thread-container" id="@containerId" data-thread-id="@threadId">
    <!-- Virtual Scroll Viewport -->
    <div class="chat-thread-viewport" id="@($"{containerId}-viewport")">
        <div class="chat-thread-content" id="@($"{containerId}-content")">
            @if (Model.Messages.Count == 0)
            {
                <!-- Welcome State -->
                <div class="chat-welcome">
                    <div class="welcome-icon">🤖</div>
                    <h2>Welcome to GMSD</h2>
                    <p>I'm here to help you manage your game development projects.</p>
                    <div class="suggested-actions">
                        <button class="suggested-action" data-command="/status" aria-label="Check workspace status">
                            <span aria-hidden="true">📊</span> Check status
                        </button>
                        <button class="suggested-action" data-command="/list projects" aria-label="List all projects">
                            <span aria-hidden="true">📁</span> View projects
                        </button>
                        <button class="suggested-action" data-command="/help" aria-label="Get help with available commands">
                            <span aria-hidden="true">❓</span> Get help
                        </button>
                    </div>
                </div>
            }
            else
            {
                <!-- Message List -->
                <div class="messages-list">
                    @for (int i = 0; i < Model.Messages.Count; i++)
                    {
                        var message = Model.Messages[i];
                        var isLast = i == Model.Messages.Count - 1;
                        <partial name="_ChatMessage" model="message" view-data="@(new ViewDataDictionary(ViewData) { { "IsLast", isLast }, { "ContainerId", containerId } })" />
                    }
                </div>
            }

            <!-- Streaming Indicator (shown when processing) -->
            @if (Model.IsProcessing)
            {
                <div class="streaming-indicator" id="@($"{containerId}-streaming")">
                    <div class="typing-dots">
                        <span></span>
                        <span></span>
                        <span></span>
                    </div>
                    <span class="streaming-text">Thinking...</span>
                </div>
            }
        </div>
    </div>

    <!-- Scroll to bottom button (appears when scrolled up) -->
    <button class="scroll-to-bottom" id="@($"{containerId}-scroll-btn")" title="Scroll to bottom" aria-label="Scroll to bottom">
        <span>↓</span>
    </button>

    <!-- Load more button (for pagination) -->
    @if (Model.HasMoreMessages)
    {
        <button class="load-more-btn" id="@($"{containerId}-load-more")" 
                hx-get="/api/chat/messages?before=@Model.Messages.FirstOrDefault()?.Id&threadId=@threadId"
                hx-target="#@($"{containerId}-content")"
                hx-swap="afterbegin"
                hx-indicator="#@($"{containerId}-loading")"
                aria-label="Load more messages">
            <span class="load-more-text">Load more messages</span>
            <span class="load-more-spinner" id="@($"{containerId}-loading")">
                <span class="spinner"></span>
            </span>
        </button>
    }
</div>

<script>
    // Initialize chat thread for this container
    (function() {
        const containerId = '@containerId';
        const threadId = '@threadId';
        
        // Store reference for global access
        if (!window.chatThreads) window.chatThreads = {};
        
        // Initialize or get existing controller
        if (!window.chatThreads[threadId]) {
            window.chatThreads[threadId] = {
                containerId: containerId,
                scrollToBottom: function() {
                    const viewport = document.getElementById(containerId + '-viewport');
                    if (viewport) {
                        viewport.scrollTop = viewport.scrollHeight;
                    }
                },
                appendMessage: function(html) {
                    const content = document.getElementById(containerId + '-content');
                    if (content) {
                        const messagesList = content.querySelector('.messages-list');
                        if (messagesList) {
                            messagesList.insertAdjacentHTML('beforeend', html);
                            this.scrollToBottom();
                        }
                    }
                }
            };
        }

        // Auto-scroll to bottom on load
        document.addEventListener('DOMContentLoaded', function() {
            const viewport = document.getElementById(containerId + '-viewport');
            if (viewport) {
                viewport.scrollTop = viewport.scrollHeight;
            }
        });
    })();
</script>
