@model Gmsd.Web.Models.RunCardModel

<div class="run-card @Model.GetStatusClass()">
    <div class="run-card-header">
        <div class="run-status-badge">@Model.Status</div>
        <div class="run-id">@Model.RunId</div>
    </div>
    <div class="run-card-body">
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p class="run-description">@Model.Description</p>
        }
        <div class="run-meta">
            @if (Model.StartedAt.HasValue)
            {
                <span class="run-time">
                    <span class="meta-icon">🕐</span>
                    Started: @Model.StartedAt.Value.ToString("MMM dd, HH:mm")
                </span>
            }
            @if (Model.Duration.HasValue)
            {
                <span class="run-duration">
                    <span class="meta-icon">⏱️</span>
                    Duration: @Model.FormatDuration()
                </span>
            }
            @if (Model.FilesTouched > 0)
            {
                <span class="run-files">
                    <span class="meta-icon">📄</span>
                    @Model.FilesTouched files touched
                </span>
            }
        </div>
        @if (Model.Tags.Any())
        {
            <div class="run-tags">
                @foreach (var tag in Model.Tags)
                {
                    <span class="run-tag">@tag</span>
                }
            </div>
        }
    </div>
    <div class="run-card-footer">
        @if (!string.IsNullOrEmpty(Model.EvidenceUrl))
        {
            <a href="@Model.EvidenceUrl" class="btn btn-sm btn-secondary">
                <span class="btn-icon">📋</span> View Evidence
            </a>
        }
        @if (!string.IsNullOrEmpty(Model.DetailsUrl))
        {
            <a href="@Model.DetailsUrl" class="btn btn-sm btn-primary">
                <span class="btn-icon">🔍</span> Details
            </a>
        }
    </div>
</div>
