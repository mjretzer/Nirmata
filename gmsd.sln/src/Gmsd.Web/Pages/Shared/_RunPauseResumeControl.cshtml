@using Gmsd.Web.Models
@model RunPauseResumeViewModel

@if (Model != null)
{
    <div class="run-pause-resume-control">
        <div class="control-header">
            <h3>Run Control</h3>
        </div>

        <div class="status-display">
            <div class="status-item">
                <label>Current Status</label>
                <span class="status-badge @GetStatusCssClass(Model.CurrentStatus)">
                    @GetStatusDisplayText(Model.CurrentStatus)
                </span>
            </div>
        </div>

        <div class="control-actions">
            @if (Model.CanPause)
            {
                <button class="btn btn-warning" 
                        onclick="pauseRun('@Model.RunId')" 
                        title="Pause this run">
                    ⏸ Pause Run
                </button>
            }

            @if (Model.CanResume)
            {
                <button class="btn btn-success" 
                        onclick="resumeRun('@Model.RunId')" 
                        title="Resume this run">
                    ▶ Resume Run
                </button>
            }

            @if (!Model.CanPause && !Model.CanResume)
            {
                <p class="text-muted">No control actions available for this run status.</p>
            }
        </div>

        @if (!string.IsNullOrEmpty(Model.LastStatusChangeTime))
        {
            <div class="status-metadata">
                <p class="text-muted">
                    <small>Last status change: @Model.LastStatusChangeTime</small>
                </p>
            </div>
        }
    </div>

    <style>
        .run-pause-resume-control {
            border: 1px solid #ddd;
            border-radius: 4px;
            padding: 16px;
            margin: 16px 0;
            background-color: #f9f9f9;
        }

        .control-header {
            margin-bottom: 12px;
        }

        .control-header h3 {
            margin: 0;
            font-size: 16px;
            font-weight: 600;
        }

        .status-display {
            margin-bottom: 16px;
        }

        .status-item {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .status-item label {
            font-weight: 600;
            min-width: 120px;
        }

        .status-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 4px;
            font-size: 14px;
            font-weight: 500;
        }

        .status-badge.status-started {
            background-color: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
        }

        .status-badge.status-paused {
            background-color: #fff3cd;
            color: #856404;
            border: 1px solid #ffeaa7;
        }

        .status-badge.status-finished {
            background-color: #d1ecf1;
            color: #0c5460;
            border: 1px solid #bee5eb;
        }

        .status-badge.status-abandoned {
            background-color: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
        }

        .control-actions {
            display: flex;
            gap: 8px;
            margin-bottom: 12px;
        }

        .control-actions .btn {
            padding: 8px 16px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.2s ease;
        }

        .control-actions .btn:hover {
            opacity: 0.9;
            transform: translateY(-1px);
        }

        .control-actions .btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }

        .btn-warning {
            background-color: #ffc107;
            color: #212529;
        }

        .btn-warning:hover:not(:disabled) {
            background-color: #e0a800;
        }

        .btn-success {
            background-color: #28a745;
            color: white;
        }

        .btn-success:hover:not(:disabled) {
            background-color: #218838;
        }

        .status-metadata {
            padding-top: 8px;
            border-top: 1px solid #ddd;
        }

        .status-metadata p {
            margin: 0;
        }

        .text-muted {
            color: #6c757d;
        }
    </style>

    <script>
        function pauseRun(runId) {
            if (confirm(`Are you sure you want to pause run ${runId}?`)) {
                fetch(`/api/runs/${runId}/pause`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                })
                .then(response => {
                    if (response.ok) {
                        alert('Run paused successfully. Refreshing page...');
                        location.reload();
                    } else {
                        alert('Failed to pause run. Please try again.');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('An error occurred while pausing the run.');
                });
            }
        }

        function resumeRun(runId) {
            if (confirm(`Are you sure you want to resume run ${runId}?`)) {
                fetch(`/api/runs/${runId}/resume`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                })
                .then(response => {
                    if (response.ok) {
                        alert('Run resumed successfully. Refreshing page...');
                        location.reload();
                    } else {
                        alert('Failed to resume run. Please try again.');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('An error occurred while resuming the run.');
                });
            }
        }
    </script>
}

@functions {
    private string GetStatusCssClass(string? status)
    {
        return status?.ToLower() switch
        {
            "started" => "status-started",
            "paused" => "status-paused",
            "finished" => "status-finished",
            "abandoned" => "status-abandoned",
            _ => "status-unknown"
        };
    }

    private string GetStatusDisplayText(string? status)
    {
        return status?.ToLower() switch
        {
            "started" => "Running",
            "paused" => "Paused",
            "finished" => "Finished",
            "abandoned" => "Abandoned",
            _ => "Unknown"
        };
    }
}
