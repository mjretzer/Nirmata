@model Gmsd.Web.Models.DiagnosticArtifactViewModel

@if (Model != null && Model.HasErrors)
{
    <div class="diagnostic-artifact-container alert alert-danger" role="alert">
        <div class="diagnostic-header">
            <h5 class="alert-heading">
                <i class="bi bi-exclamation-triangle-fill"></i>
                Validation Failed
            </h5>
            <div class="diagnostic-meta">
                <small class="text-muted">
                    Phase: <strong>@Model.Phase</strong> | 
                    Errors: <strong>@Model.ErrorCount</strong> | 
                    Timestamp: <strong>@Model.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</strong>
                </small>
            </div>
        </div>

        <div class="diagnostic-content">
            <div class="artifact-info">
                <p class="mb-2">
                    <strong>Artifact:</strong> <code>@Model.ArtifactPath</code>
                </p>
                <p class="mb-3">
                    <strong>Failed Schema:</strong> <code>@Model.FailedSchemaId</code> (v@Model.FailedSchemaVersion)
                </p>
            </div>

            @if (Model.ValidationErrors.Count > 0)
            {
                <div class="validation-errors">
                    <h6>Validation Errors</h6>
                    <div class="error-list">
                        @foreach (var error in Model.ValidationErrors)
                        {
                            <div class="error-item card mb-2">
                                <div class="card-body p-3">
                                    <div class="error-path">
                                        <code>@error.Path</code>
                                    </div>
                                    <p class="error-message mb-2">@error.Message</p>
                                    @if (!string.IsNullOrEmpty(error.Expected) || !string.IsNullOrEmpty(error.Actual))
                                    {
                                        <div class="error-details">
                                            @if (!string.IsNullOrEmpty(error.Expected))
                                            {
                                                <div class="detail-row">
                                                    <span class="label">Expected:</span>
                                                    <code>@error.Expected</code>
                                                </div>
                                            }
                                            @if (!string.IsNullOrEmpty(error.Actual))
                                            {
                                                <div class="detail-row">
                                                    <span class="label">Actual:</span>
                                                    <code>@error.Actual</code>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            @if (Model.RepairSuggestions.Count > 0)
            {
                <div class="repair-suggestions mt-4">
                    <h6>
                        <i class="bi bi-lightbulb-fill"></i>
                        Repair Suggestions
                    </h6>
                    <ul class="suggestion-list">
                        @foreach (var suggestion in Model.RepairSuggestions)
                        {
                            <li class="suggestion-item">@suggestion</li>
                        }
                    </ul>
                </div>
            }

            @if (Model.Context.Count > 0)
            {
                <div class="diagnostic-context mt-3">
                    <h6>Context</h6>
                    <dl class="row">
                        @foreach (var ctx in Model.Context)
                        {
                            <dt class="col-sm-3">@ctx.Key</dt>
                            <dd class="col-sm-9"><code>@ctx.Value</code></dd>
                        }
                    </dl>
                </div>
            }
        </div>
    </div>

    <style>
        .diagnostic-artifact-container {
            border-left: 4px solid #dc3545;
            margin-bottom: 1.5rem;
        }

        .diagnostic-header {
            margin-bottom: 1rem;
        }

        .diagnostic-header h5 {
            margin-bottom: 0.5rem;
        }

        .diagnostic-meta {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .artifact-info {
            background-color: #f8f9fa;
            padding: 1rem;
            border-radius: 0.25rem;
            margin-bottom: 1rem;
        }

        .artifact-info p {
            margin-bottom: 0.5rem;
        }

        .artifact-info code {
            background-color: #e9ecef;
            padding: 0.2rem 0.4rem;
            border-radius: 0.2rem;
            word-break: break-all;
        }

        .validation-errors {
            margin-bottom: 1rem;
        }

        .validation-errors h6 {
            color: #dc3545;
            margin-bottom: 0.75rem;
            font-weight: 600;
        }

        .error-item {
            border-left: 3px solid #dc3545;
            background-color: #fff5f5;
        }

        .error-path {
            font-weight: 600;
            color: #721c24;
            margin-bottom: 0.5rem;
        }

        .error-path code {
            background-color: #f8d7da;
            padding: 0.2rem 0.4rem;
            border-radius: 0.2rem;
        }

        .error-message {
            color: #721c24;
        }

        .error-details {
            margin-top: 0.75rem;
            padding-top: 0.75rem;
            border-top: 1px solid #f5c6cb;
        }

        .detail-row {
            margin-bottom: 0.5rem;
            font-size: 0.9rem;
        }

        .detail-row .label {
            font-weight: 600;
            display: inline-block;
            width: 80px;
        }

        .detail-row code {
            background-color: #f8d7da;
            padding: 0.2rem 0.4rem;
            border-radius: 0.2rem;
            word-break: break-all;
        }

        .repair-suggestions {
            background-color: #fff3cd;
            border-left: 3px solid #ffc107;
            padding: 1rem;
            border-radius: 0.25rem;
        }

        .repair-suggestions h6 {
            color: #856404;
            margin-bottom: 0.75rem;
            font-weight: 600;
        }

        .suggestion-list {
            margin-bottom: 0;
            padding-left: 1.5rem;
        }

        .suggestion-item {
            color: #856404;
            margin-bottom: 0.5rem;
        }

        .diagnostic-context {
            background-color: #f8f9fa;
            padding: 1rem;
            border-radius: 0.25rem;
        }

        .diagnostic-context h6 {
            margin-bottom: 0.75rem;
            font-weight: 600;
        }

        .diagnostic-context dt {
            font-weight: 600;
        }

        .diagnostic-context dd {
            margin-bottom: 0.5rem;
        }

        .diagnostic-context code {
            background-color: #e9ecef;
            padding: 0.2rem 0.4rem;
            border-radius: 0.2rem;
            word-break: break-all;
        }
    </style>
}
