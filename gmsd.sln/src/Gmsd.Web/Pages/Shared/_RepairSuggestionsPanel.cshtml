@model Gmsd.Web.Models.DiagnosticArtifactViewModel

@if (Model != null && Model.HasSuggestions)
{
    <div class="repair-suggestions-panel card">
        <div class="card-header bg-warning text-dark">
            <h5 class="mb-0">
                <i class="bi bi-lightbulb-fill"></i>
                Repair Suggestions
            </h5>
        </div>
        <div class="card-body">
            @if (Model.RepairSuggestions.Count > 0)
            {
                <ol class="repair-list">
                    @foreach (var suggestion in Model.RepairSuggestions)
                    {
                        <li class="repair-item">
                            <span>@suggestion</span>
                        </li>
                    }
                </ol>
            }
            else
            {
                <p class="text-muted mb-0">No repair suggestions available.</p>
            }
        </div>
    </div>

    <style>
        .repair-suggestions-panel {
            margin-bottom: 1.5rem;
            border: 1px solid #ffc107;
        }

        .repair-suggestions-panel .card-header {
            border-bottom: 2px solid #ffc107;
        }

        .repair-suggestions-panel .card-header h5 {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .repair-list {
            margin-bottom: 0;
            padding-left: 1.5rem;
        }

        .repair-item {
            margin-bottom: 0.75rem;
            line-height: 1.5;
        }

        .repair-item span {
            color: #333;
        }

        .repair-item:last-child {
            margin-bottom: 0;
        }
    </style>
}
