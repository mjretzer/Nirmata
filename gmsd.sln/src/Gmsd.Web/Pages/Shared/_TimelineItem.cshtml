@model Gmsd.Web.Models.PhaseTimelineViewModel

<div class="timeline-item @(Model.Status == Gmsd.Web.Models.SpecItemStatus.InProgress ? "active" : "") @(Model.Status == Gmsd.Web.Models.SpecItemStatus.Completed ? "completed" : "")">
    <div class="timeline-marker">
        @if (Model.Status == Gmsd.Web.Models.SpecItemStatus.Completed)
        {
            <span class="marker-icon">&#10003;</span>
        }
        else if (Model.Status == Gmsd.Web.Models.SpecItemStatus.InProgress)
        {
            <span class="marker-icon pulse">&#9679;</span>
        }
        else
        {
            <span class="marker-icon">&#9679;</span>
        }
    </div>
    <div class="timeline-content">
        <h4 class="timeline-title">@Model.Name</h4>
        <div class="timeline-meta">
            <partial name="_StatusBadge" model="Model.Status" />
            @if (Model.StartDate.HasValue)
            {
                <span class="timeline-date">@Model.StartDate.Value.ToString("MMM d")</span>
            }
            @if (Model.DurationDays > 0)
            {
                <span class="timeline-duration">(@Model.DurationDays days)</span>
            }
        </div>
    </div>
</div>
