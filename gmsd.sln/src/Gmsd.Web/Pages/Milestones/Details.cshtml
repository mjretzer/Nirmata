@page "{id}"
@model Gmsd.Web.Pages.Milestones.DetailsModel
@using Gmsd.Web.Models
@{
    ViewData["Title"] = $"Milestone: {Model.Milestone.Name}";
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-error">
        @Model.ErrorMessage
    </div>
}

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">
        @Model.SuccessMessage
    </div>
}

<div class="detail-page">
    <div class="detail-header">
        <div class="detail-title">
            <h1>@Model.Milestone.Name</h1>
            <span class="badge @(Model.Milestone.Status switch {
                SpecItemStatus.Completed or SpecItemStatus.Verified => "badge-success",
                SpecItemStatus.InProgress => "badge-warning",
                SpecItemStatus.Blocked => "badge-error",
                SpecItemStatus.Draft => "badge-info",
                _ => "badge-info"
            })">
                @Model.Milestone.Status
            </span>
        </div>
        <div class="detail-meta">
            <span>ID: @Model.Milestone.Id</span>
            @if (Model.Milestone.TargetDate.HasValue)
            {
                <span>Target: @Model.Milestone.TargetDate.Value.ToString("MMM dd, yyyy")</span>
            }
            <span>@Model.Milestone.Phases.Count phases</span>
        </div>
        <div class="detail-actions">
            <a href="~/Milestones" class="btn btn-secondary">← Back to Milestones</a>
            <a href="~/Roadmap" class="btn btn-secondary">View in Roadmap</a>
            @if (Model.Milestone.Status != SpecItemStatus.Completed && Model.Milestone.Status != SpecItemStatus.Verified)
            {
                <form method="post" asp-page-handler="Complete" asp-route-id="@Model.Milestone.Id" style="display: inline;">
                    <button type="submit" class="btn btn-primary" 
                            onclick="return confirm('Mark this milestone as complete? All phases must be completed first.');">
                        Complete Milestone
                    </button>
                </form>
            }
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Milestone.Description))
    {
        <div class="section-card">
            <div class="section-header">
                <h3 class="section-title">Description</h3>
            </div>
            <div class="section-content">
                <p>@Model.Milestone.Description</p>
            </div>
        </div>
    }

    <div class="section-card">
        <div class="section-header">
            <h3 class="section-title">Progress</h3>
        </div>
        <div class="section-content">
            <div class="milestone-progress">
                <div class="progress-bar">
                    <div class="progress-fill" style="width: @Model.Milestone.ProgressPercent%"></div>
                </div>
                <div class="progress-text">@Model.Milestone.ProgressPercent% Complete (@Model.Milestone.CompletedTasks / @Model.Milestone.TotalTasks phases)</div>
            </div>

            @if (Model.Milestone.HasCompletionGate)
            {
                <div class="alert alert-success mt-2">
                    <strong>✓ Completion Gate Passed</strong>
                    @if (!string.IsNullOrEmpty(Model.Milestone.GateValidationMessage))
                    {
                        <p>@Model.Milestone.GateValidationMessage</p>
                    }
                </div>
            }
        </div>
    </div>

    <div class="section-card">
        <div class="section-header">
            <h3 class="section-title">Phases</h3>
        </div>
        <div class="section-content">
            @if (Model.Milestone.Phases.Any())
            {
                <table class="table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Status</th>
                            <th>Tasks</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var phase in Model.Milestone.Phases)
                        {
                            <tr>
                                <td><strong>@phase.Name</strong></td>
                                <td>
                                    <span class="badge @(phase.Status switch {
                                        SpecItemStatus.Completed or SpecItemStatus.Verified => "badge-success",
                                        SpecItemStatus.InProgress => "badge-warning",
                                        SpecItemStatus.Blocked => "badge-error",
                                        SpecItemStatus.Draft => "badge-info",
                                        _ => "badge-info"
                                    })">
                                        @phase.Status
                                    </span>
                                </td>
                                <td>@phase.TaskCount completed / @phase.CompletedTaskCount</td>
                                <td>
                                    <a href="~/Phases/Details/@phase.Id" class="btn btn-sm btn-secondary">View</a>
                                    <a href="~/Tasks?phaseId=@phase.Id" class="btn btn-sm btn-primary">Tasks</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-state">
                    <p class="text-muted">No phases defined for this milestone yet.</p>
                    <a href="~/Roadmap" class="btn btn-primary">Add Phases in Roadmap</a>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .milestone-progress {
        margin-bottom: 1rem;
    }

    .milestone-progress .progress-bar {
        height: 12px;
        background-color: #ecf0f1;
        border-radius: 6px;
        overflow: hidden;
        margin-bottom: 0.5rem;
    }

    .milestone-progress .progress-fill {
        height: 100%;
        background-color: #27ae60;
        transition: width 0.3s ease;
    }

    .milestone-progress .progress-text {
        font-size: 0.875rem;
        color: #7f8c8d;
    }

    .mt-2 {
        margin-top: 1rem;
    }
</style>
