@page
@model Gmsd.Web.Pages.State.IndexModel
@{
    ViewData["Title"] = "State & Events";
}

<h1>State & Events</h1>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-error">
        @Model.ErrorMessage
    </div>
}

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">
        @Model.SuccessMessage
    </div>
}

@if (string.IsNullOrEmpty(Model.WorkspacePath))
{
    <div class="empty-state">
        <div class="empty-state-icon">📁</div>
        <h3>No Workspace Selected</h3>
        <p>Please select a workspace to view state and events.</p>
        <a href="~/Workspace" class="btn btn-primary">Select Workspace</a>
    </div>
}
else
{
    <!-- State Section -->
    <div class="dashboard-card mb-4">
        <div class="dashboard-header">
            <h2>Current State</h2>
            @if (Model.StateExists)
            {
                <span class="badge badge-success">Active</span>
            }
            else
            {
                <span class="badge badge-secondary">No State</span>
            }
        </div>
        <div class="dashboard-body">
            @if (Model.StateExists)
            {
                @if (Model.StateSnapshot?.Cursor != null)
                {
                    var cursor = Model.StateSnapshot.Cursor;
                    <div class="cursor-display mb-3">
                        <h4>Cursor</h4>
                        <div class="cursor-grid">
                            @if (!string.IsNullOrEmpty(cursor.MilestoneId))
                            {
                                <div class="cursor-item">
                                    <span class="cursor-label">Milestone:</span>
                                    <span class="cursor-value">@cursor.MilestoneId</span>
                                    <span class="badge @GetStatusBadgeClass(cursor.MilestoneStatus)">@cursor.MilestoneStatus</span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(cursor.PhaseId))
                            {
                                <div class="cursor-item">
                                    <span class="cursor-label">Phase:</span>
                                    <span class="cursor-value">@cursor.PhaseId</span>
                                    <span class="badge @GetStatusBadgeClass(cursor.PhaseStatus)">@cursor.PhaseStatus</span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(cursor.TaskId))
                            {
                                <div class="cursor-item">
                                    <span class="cursor-label">Task:</span>
                                    <span class="cursor-value">@cursor.TaskId</span>
                                    <span class="badge @GetStatusBadgeClass(cursor.TaskStatus)">@cursor.TaskStatus</span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(cursor.StepId))
                            {
                                <div class="cursor-item">
                                    <span class="cursor-label">Step:</span>
                                    <span class="cursor-value">@cursor.StepId</span>
                                    <span class="badge @GetStatusBadgeClass(cursor.StepStatus)">@cursor.StepStatus</span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(cursor.Kind) || !string.IsNullOrEmpty(cursor.Id))
                            {
                                <div class="cursor-item cursor-legacy">
                                    <span class="cursor-label">Legacy:</span>
                                    <span class="cursor-value">@cursor.Kind / @cursor.Id</span>
                                </div>
                            }
                        </div>
                    </div>
                }

                <div class="state-json-section">
                    <h4>State JSON</h4>
                    @await Html.PartialAsync("Shared/_JsonViewer", new Gmsd.Web.Models.JsonViewerModel
                    {
                        JsonContent = Model.StateJsonContent ?? "{}",
                        FileName = "state.json",
                        ShowToolbar = true,
                        AllowDownload = true,
                        DownloadUrl = $"data:application/json;base64,{Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(Model.StateJsonContent ?? "{}"))}"
                    })
                </div>
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-state-icon">📄</div>
                    <h3>No State File</h3>
                    <p>The state.json file does not exist in this workspace.</p>
                </div>
            }
        </div>
    </div>

    <!-- Events Section -->
    <div class="dashboard-card mb-4"
         @if (Model.AutoRefresh)
         {
             <text>hx-get="@Url.Page("State", new { EventTypeFilter = Model.EventTypeFilter, MaxEvents = Model.MaxEvents, AutoRefresh = true })" hx-trigger="every 5s" hx-swap="outerHTML"</text>
         }>
        <div class="dashboard-header">
            <h2>Events (@Model.Events.Count)</h2>
            <div class="events-controls">
                <!-- Event Type Filter -->
                <div class="filter-dropdown">
                    <form method="post" asp-page-handler="Filter" class="d-inline">
                        <select name="eventType" class="form-select" onchange="this.form.submit()">
                            <option value="">All Types</option>
                            @foreach (var type in Model.EventTypes.OrderBy(t => t))
                            {
                                <option value="@type" selected="@(Model.EventTypeFilter == type ? "selected" : null)">@type</option>
                            }
                        </select>
                    </form>
                </div>

                <!-- Refresh Controls -->
                <form method="post" asp-page-handler="ToggleAutoRefresh" class="d-inline ml-2">
                    <button type="submit" class="btn btn-sm @(Model.AutoRefresh ? "btn-success" : "btn-secondary")">
                        @(Model.AutoRefresh ? "⏸ Auto" : "▶ Auto")
                    </button>
                </form>

                <form method="post" asp-page-handler="Refresh" class="d-inline ml-2">
                    <input type="hidden" name="EventTypeFilter" value="@Model.EventTypeFilter" />
                    <input type="hidden" name="MaxEvents" value="@Model.MaxEvents" />
                    <input type="hidden" name="AutoRefresh" value="@Model.AutoRefresh.ToString().ToLower()" />
                    <button type="submit" class="btn btn-sm btn-primary">
                        <span class="btn-icon">🔄</span> Refresh
                    </button>
                </form>
            </div>
        </div>
        <div class="dashboard-body">
            @if (Model.Events.Count == 0)
            {
                <div class="empty-state">
                    <div class="empty-state-icon">📋</div>
                    <h3>No Events</h3>
                    <p>No events found matching the current filter.</p>
                </div>
            }
            else
            {
                <div class="events-list">
                    @foreach (var evt in Model.Events.OrderByDescending(e => e.LineNumber))
                    {
                        <div class="event-item" data-event-type="@evt.EventType">
                            <div class="event-header">
                                <span class="badge @GetEventTypeBadgeClass(evt.EventType)">@evt.EventType</span>
                                <span class="event-line">Line @evt.LineNumber</span>
                                @if (evt.Timestamp.HasValue)
                                {
                                    <span class="event-timestamp">@evt.Timestamp.Value.ToString("yyyy-MM-dd HH:mm:ss")</span>
                                }
                            </div>
                            <div class="event-payload">
                                <pre class="language-json"><code>@evt.FormattedPayload</code></pre>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- History Summary Section -->
    <div class="dashboard-card mb-4">
        <div class="dashboard-header">
            <h2>History Summary</h2>
        </div>
        <div class="dashboard-body">
            @if (Model.HistoryEntries.Count == 0)
            {
                <div class="empty-state">
                    <div class="empty-state-icon">📊</div>
                    <h3>No History</h3>
                    <p>No event history available.</p>
                </div>
            }
            else
            {
                <div class="history-table-container">
                    <table class="history-table">
                        <thead>
                            <tr>
                                <th>Run / Task / Step</th>
                                <th>Events</th>
                                <th>Types</th>
                                <th>Last Activity</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var entry in Model.HistoryEntries)
                            {
                                <tr>
                                    <td class="history-key">@entry.DisplayKey</td>
                                    <td class="history-count">@entry.EventCount</td>
                                    <td class="history-types">
                                        @foreach (var type in entry.EventTypes.Take(3))
                                        {
                                            <span class="badge badge-small @GetEventTypeBadgeClass(type)">@type</span>
                                        }
                                        @if (entry.EventTypes.Count > 3)
                                        {
                                            <span class="badge badge-small badge-secondary">+@(entry.EventTypes.Count - 3)</span>
                                        }
                                    </td>
                                    <td class="history-time">
                                        @if (entry.LastEventAt.HasValue)
                                        {
                                            <span title="@entry.LastEventAt.Value.ToString("yyyy-MM-dd HH:mm:ss.fff")">
                                                @entry.LastEventAt.Value.ToString("HH:mm:ss")
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <div class="mt-3">
        <a href="~/" class="btn btn-secondary">← Back to Dashboard</a>
    </div>
}

@functions {
    string GetStatusBadgeClass(string? status) => status?.ToLower() switch
    {
        "completed" => "badge-success",
        "running" => "badge-primary",
        "pending" => "badge-warning",
        "blocked" => "badge-danger",
        "failed" => "badge-danger",
        _ => "badge-secondary"
    };

    string GetEventTypeBadgeClass(string eventType) => eventType.ToLower() switch
    {
        "statechange" => "badge-primary",
        "decision" => "badge-success",
        "blocker" => "badge-danger",
        "gating" => "badge-warning",
        "error" => "badge-danger",
        "warning" => "badge-warning",
        "info" => "badge-info",
        "taskstart" => "badge-primary",
        "taskcomplete" => "badge-success",
        "taskfailed" => "badge-danger",
        "checkpoint" => "badge-info",
        _ => "badge-secondary"
    };
}

<style>
    .cursor-display {
        background: var(--info-bg, #f8f9fa);
        padding: 1rem;
        border-radius: 6px;
        border: 1px solid var(--border-color, #e1e4e8);
    }

    .cursor-display h4 {
        margin-top: 0;
        margin-bottom: 0.75rem;
        color: var(--text-primary, #212529);
    }

    .cursor-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 0.5rem;
    }

    .cursor-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem;
        background: white;
        border-radius: 4px;
        border: 1px solid var(--border-color, #e1e4e8);
    }

    .cursor-legacy {
        opacity: 0.7;
        background: #f0f0f0;
    }

    .cursor-label {
        font-weight: 600;
        color: var(--text-muted, #6c757d);
        min-width: 80px;
    }

    .cursor-value {
        font-family: monospace;
        font-size: 0.9rem;
        flex: 1;
    }

    .state-json-section h4 {
        margin-top: 1rem;
        margin-bottom: 0.75rem;
    }

    .events-controls {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .filter-dropdown select {
        padding: 0.375rem 1.75rem 0.375rem 0.75rem;
        border: 1px solid var(--border-color, #e1e4e8);
        border-radius: 4px;
        background-color: white;
    }

    .events-list {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        max-height: 600px;
        overflow-y: auto;
    }

    .event-item {
        border: 1px solid var(--border-color, #e1e4e8);
        border-radius: 6px;
        overflow: hidden;
    }

    .event-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.5rem 0.75rem;
        background: var(--header-bg, #f6f8fa);
        border-bottom: 1px solid var(--border-color, #e1e4e8);
    }

    .event-line {
        font-family: monospace;
        font-size: 0.8rem;
        color: var(--text-muted, #6c757d);
    }

    .event-timestamp {
        font-size: 0.8rem;
        color: var(--text-muted, #6c757d);
        margin-left: auto;
    }

    .event-payload {
        padding: 0.75rem;
    }

    .event-payload pre {
        margin: 0;
        font-size: 0.8rem;
        max-height: 200px;
        overflow-y: auto;
    }

    .history-table-container {
        overflow-x: auto;
    }

    .history-table {
        width: 100%;
        border-collapse: collapse;
    }

    .history-table th,
    .history-table td {
        padding: 0.75rem;
        text-align: left;
        border-bottom: 1px solid var(--border-color, #e1e4e8);
    }

    .history-table th {
        font-weight: 600;
        background: var(--header-bg, #f6f8fa);
    }

    .history-table tr:hover {
        background: var(--hover-bg, #f8f9fa);
    }

    .history-key {
        font-family: monospace;
        font-size: 0.85rem;
    }

    .history-count {
        font-weight: 600;
        text-align: center;
    }

    .history-types {
        display: flex;
        flex-wrap: wrap;
        gap: 0.25rem;
    }

    .history-time {
        font-family: monospace;
        font-size: 0.85rem;
    }

    .badge-small {
        font-size: 0.7rem;
        padding: 0.15rem 0.4rem;
    }

    .badge-info {
        background: #17a2b8;
        color: white;
    }

    .ml-2 {
        margin-left: 0.5rem;
    }

    .d-inline {
        display: inline;
    }
</style>
