@page "{id}"
@model Gmsd.Web.Pages.Tasks.DetailsModel
@using Gmsd.Web.Models
@{
    ViewData["Title"] = $"Task: {Model.Task.Title}";
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-error">
        @Model.ErrorMessage
    </div>
}

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">
        @Model.SuccessMessage
    </div>
}

<div class="detail-page">
    <div class="detail-header">
        <div class="detail-title">
            <h1>@Model.Task.Title</h1>
            <span class="badge @(Model.Task.Status switch {
                SpecItemStatus.Completed or SpecItemStatus.Verified => "badge-success",
                SpecItemStatus.InProgress => "badge-warning",
                SpecItemStatus.Failed => "badge-error",
                SpecItemStatus.Blocked => "badge-error",
                SpecItemStatus.Draft => "badge-info",
                _ => "badge-info"
            })">
                @Model.Task.Status
            </span>
        </div>
        <div class="detail-meta">
            <span>ID: <code>@Model.Task.Id</code></span>
            @if (!string.IsNullOrEmpty(Model.Task.PhaseName))
            {
                <span>Phase: <a href="~/Phases/Details/@Model.Task.PhaseId">@Model.Task.PhaseName</a></span>
            }
            @if (!string.IsNullOrEmpty(Model.Task.MilestoneName))
            {
                <span>Milestone: @Model.Task.MilestoneName</span>
            }
            @if (Model.Task.CreatedAt.HasValue)
            {
                <span>Created: @Model.Task.CreatedAt.Value.ToString("yyyy-MM-dd")</span>
            }
        </div>
        <div class="detail-actions">
            <a href="~/Tasks" class="btn btn-secondary">← Back to Tasks</a>
            <a href="~/Phases/Details/@Model.Task.PhaseId" class="btn btn-secondary">View Phase</a>
            
            @if (!string.IsNullOrEmpty(Model.Task.LatestRunId))
            {
                <a href="~/Runs/Details/@Model.Task.LatestRunId" class="btn btn-secondary">View Latest Run</a>
            }

            @if (Model.Task.Status == SpecItemStatus.Draft || Model.Task.Status == SpecItemStatus.Planned || Model.Task.Status == SpecItemStatus.Failed)
            {
                <form method="post" asp-page-handler="ExecutePlan" asp-route-id="@Model.Task.Id" style="display: inline;">
                    <button type="submit" class="btn btn-primary">Execute Plan</button>
                </form>
            }

            <form method="post" asp-page-handler="MarkStatus" asp-route-id="@Model.Task.Id" style="display: inline;">
                <select name="NewStatus" class="filter-select" onchange="if(this.value) { this.form.submit(); }">
                    <option value="">Mark Status...</option>
                    <option value="Draft">Draft</option>
                    <option value="Pending">Pending</option>
                    <option value="InProgress">In Progress</option>
                    <option value="Completed">Completed</option>
                    <option value="Failed">Failed</option>
                    <option value="Verified">Verified</option>
                </select>
            </form>
        </div>
    </div>

    <div class="section-card mb-3">
        <div class="section-header">
            <h3 class="section-title">Description</h3>
        </div>
        <div class="section-content">
            @if (!string.IsNullOrEmpty(Model.Task.Description))
            {
                <p>@Model.Task.Description</p>
            }
            else
            {
                <p class="text-muted">No description provided.</p>
            }
        </div>
    </div>

    @if (Model.Task.AcceptanceCriteria.Any())
    {
        <div class="section-card mb-3">
            <div class="section-header">
                <h3 class="section-title">Acceptance Criteria</h3>
            </div>
            <div class="section-content">
                <ul class="item-list">
                    @foreach (var criterion in Model.Task.AcceptanceCriteria)
                    {
                        <li><span class="item-bullet">☐</span> @criterion</li>
                    }
                </ul>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.Task.LatestRunId))
    {
        <div class="section-card mb-3">
            <div class="section-header">
                <h3 class="section-title">Latest Run</h3>
            </div>
            <div class="section-content">
                <div class="quick-stats">
                    <div class="stat-card">
                        <span class="stat-value"><code>@Model.Task.LatestRunId</code></span>
                        <span class="stat-label">Run ID</span>
                    </div>
                    @if (Model.Task.LatestRunAt.HasValue)
                    {
                        <div class="stat-card">
                            <span class="stat-value">@Model.Task.LatestRunAt.Value.ToString("yyyy-MM-dd HH:mm")</span>
                            <span class="stat-label">Run Date</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Task.LatestRunStatus))
                    {
                        <div class="stat-card">
                            <span class="stat-value">@Model.Task.LatestRunStatus</span>
                            <span class="stat-label">Run Status</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <div class="tabs-container">
        <div class="tabs-header">
            <button class="tab-button @(Model.ActiveTab == "task" ? "active" : "")" 
                    onclick="switchTab('task')">task.json</button>
            <button class="tab-button @(Model.ActiveTab == "plan" ? "active" : "")" 
                    onclick="switchTab('plan')">plan.json</button>
            <button class="tab-button @(Model.ActiveTab == "uat" ? "active" : "")" 
                    onclick="switchTab('uat')">uat.json</button>
            <button class="tab-button @(Model.ActiveTab == "links" ? "active" : "")" 
                    onclick="switchTab('links')">links.json</button>
        </div>

        <div class="tabs-content">
            <!-- task.json Tab -->
            <div id="tab-task" class="tab-content @(Model.ActiveTab == "task" ? "active" : "")">
                <div class="section-card">
                    <div class="section-header">
                        <h3 class="section-title">Task Definition</h3>
                    </div>
                    <div class="section-content">
                        @if (!string.IsNullOrEmpty(Model.TaskJson))
                        {
                            <pre class="json-viewer"><code>@Model.TaskJson</code></pre>
                        }
                        else
                        {
                            <div class="empty-state">
                                <p class="text-muted">task.json not found.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- plan.json Tab -->
            <div id="tab-plan" class="tab-content @(Model.ActiveTab == "plan" ? "active" : "")">
                @if (Model.PlanValidationStatus != null)
                {
                    @await Html.PartialAsync("_ValidationStatusIndicator", Model.PlanValidationStatus)
                }
                
                @if (Model.PlanDiagnostic != null)
                {
                    @await Html.PartialAsync("_DiagnosticArtifactRenderer", Model.PlanDiagnostic)
                    @await Html.PartialAsync("_RepairSuggestionsPanel", Model.PlanDiagnostic)
                }
                
                <div class="section-card">
                    <div class="section-header">
                        <h3 class="section-title">Execution Plan</h3>
                    </div>
                    <div class="section-content">
                        @if (!string.IsNullOrEmpty(Model.PlanJson))
                        {
                            <pre class="json-viewer"><code>@Model.PlanJson</code></pre>
                        }
                        else
                        {
                            <div class="empty-state">
                                <p class="text-muted">plan.json not found.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- uat.json Tab -->
            <div id="tab-uat" class="tab-content @(Model.ActiveTab == "uat" ? "active" : "")">
                @if (Model.UatValidationStatus != null)
                {
                    @await Html.PartialAsync("_ValidationStatusIndicator", Model.UatValidationStatus)
                }
                
                @if (Model.UatDiagnostic != null)
                {
                    @await Html.PartialAsync("_DiagnosticArtifactRenderer", Model.UatDiagnostic)
                    @await Html.PartialAsync("_RepairSuggestionsPanel", Model.UatDiagnostic)
                }
                
                <div class="section-card">
                    <div class="section-header">
                        <h3 class="section-title">UAT / Verification</h3>
                    </div>
                    <div class="section-content">
                        @if (!string.IsNullOrEmpty(Model.UatJson))
                        {
                            <pre class="json-viewer"><code>@Model.UatJson</code></pre>
                            
                            @if (Model.Task.VerificationSteps.Any())
                            {
                                <div class="mt-3">
                                    <h4>Verification Steps</h4>
                                    <ul class="item-list">
                                        @foreach (var step in Model.Task.VerificationSteps)
                                        {
                                            <li><span class="item-bullet">☐</span> @step</li>
                                        }
                                    </ul>
                                </div>
                            }
                            
                            <div class="mt-3">
                                <a href="~/Uat/Verify?taskId=@Model.Task.Id" class="btn btn-primary">Run UAT Verification</a>
                            </div>
                        }
                        else
                        {
                            <div class="empty-state">
                                <p class="text-muted">uat.json not found.</p>
                                <a href="~/Uat/Verify?taskId=@Model.Task.Id" class="btn btn-primary mt-2">Run UAT Verification</a>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- links.json Tab -->
            <div id="tab-links" class="tab-content @(Model.ActiveTab == "links" ? "active" : "")">
                <div class="section-card">
                    <div class="section-header">
                        <h3 class="section-title">Links & Relationships</h3>
                    </div>
                    <div class="section-content">
                        @if (!string.IsNullOrEmpty(Model.LinksJson))
                        {
                            <pre class="json-viewer"><code>@Model.LinksJson</code></pre>
                            
                            @if (Model.Task.Links.Any())
                            {
                                <div class="mt-3">
                                    <h4>Related Items</h4>
                                    <table class="table table-sm">
                                        <thead>
                                            <tr>
                                                <th>Type</th>
                                                <th>Target</th>
                                                <th>Relationship</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var link in Model.Task.Links)
                                            {
                                                <tr>
                                                    <td>@link.Type</td>
                                                    <td>
                                                        @if (link.Type == "phase")
                                                        {
                                                            <a href="~/Phases/Details/@link.TargetId">@link.TargetName</a>
                                                        }
                                                        else if (link.Type == "milestone")
                                                        {
                                                            <a href="~/Milestones/Details/@link.TargetId">@link.TargetName</a>
                                                        }
                                                        else
                                                        {
                                                            <code>@link.TargetId</code>
                                                        }
                                                    </td>
                                                    <td>@link.Relationship</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="empty-state">
                                <p class="text-muted">links.json not found.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function switchTab(tabId) {
        // Hide all tab contents
        document.querySelectorAll('.tab-content').forEach(content => {
            content.classList.remove('active');
        });
        
        // Remove active from all buttons
        document.querySelectorAll('.tab-button').forEach(button => {
            button.classList.remove('active');
        });
        
        // Show selected tab
        document.getElementById('tab-' + tabId).classList.add('active');
        
        // Activate button
        event.target.classList.add('active');
    }
</script>

<style>
    .json-viewer {
        background-color: #f8f9fa;
        border: 1px solid #ecf0f1;
        border-radius: 6px;
        padding: 1rem;
        font-family: 'Consolas', 'Monaco', 'Courier New', monospace;
        font-size: 0.875rem;
        line-height: 1.5;
        overflow-x: auto;
        white-space: pre-wrap;
        word-wrap: break-word;
        max-height: 500px;
        overflow-y: auto;
    }

    .json-viewer code {
        font-family: inherit;
        background: none;
        padding: 0;
    }
</style>
