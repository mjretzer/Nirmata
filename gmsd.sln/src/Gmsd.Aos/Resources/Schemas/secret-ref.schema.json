{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gmsd:aos:schema:secret-ref:v1",
  "title": "AOS Secret Reference",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind"
  ],
  "properties": {
    "kind": {
      "type": "string",
      "enum": [
        "env"
      ]
    },
    "env": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "kind": {
            "const": "env"
          }
        },
        "required": [
          "kind"
        ]
      },
      "then": {
        "required": [
          "env"
        ]
      }
    }
  ]
}

