{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gmsd:aos:schema:event:v1",
  "title": "AOS Event (event.json / events.ndjson line)",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "eventType": {
      "type": "string"
    },
    "timestampUtc": {
      "type": "string"
    },
    "data": {
      "type": "object",
      "additionalProperties": true
    }
  }
}

