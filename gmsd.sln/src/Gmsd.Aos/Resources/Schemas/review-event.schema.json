{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gmsd:aos:schema:review-event:v1",
  "title": "AOS Review Event (state/events.ndjson)",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "eventType",
    "timestampUtc",
    "todoId",
    "decision"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "eventType": {
      "type": "string",
      "const": "review"
    },
    "timestampUtc": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the review occurred"
    },
    "todoId": {
      "type": "string",
      "description": "Reference to the reviewed TODO"
    },
    "decision": {
      "type": "string",
      "enum": ["promote-task", "promote-roadmap", "discard"],
      "description": "Review decision: promote to task, promote to roadmap phase, or discard"
    },
    "targetId": {
      "type": "string",
      "description": "ID of the created task or phase (if promoted)"
    },
    "rationale": {
      "type": "string",
      "description": "Reasoning behind the review decision"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "description": "Additional review metadata"
    }
  }
}
