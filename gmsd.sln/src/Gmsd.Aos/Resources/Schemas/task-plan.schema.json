{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gmsd:aos:schema:task-plan:v1",
  "title": "AOS Task Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "taskId",
    "title",
    "description",
    "fileScopes"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "taskId": {
      "type": "string",
      "minLength": 1
    },
    "phaseId": {
      "type": "string"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "fileScopes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "path"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "scopeType": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "mustExist": {
            "type": "boolean"
          }
        }
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "stepId",
          "description"
        ],
        "properties": {
          "stepId": {
            "type": "string",
            "minLength": 1
          },
          "stepType": {
            "type": "string"
          },
          "targetPath": {
            "type": "string"
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "verificationSteps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "description"
        ],
        "properties": {
          "verificationType": {
            "type": "string"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "expectedOutcome": {
            "type": "string"
          },
          "command": {
            "type": "string"
          }
        }
      }
    },
    "acceptanceCriteria": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "description"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "checkType": {
            "type": "string"
          },
          "targetPath": {
            "type": "string"
          },
          "expectedContent": {
            "type": "string"
          },
          "isRequired": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
