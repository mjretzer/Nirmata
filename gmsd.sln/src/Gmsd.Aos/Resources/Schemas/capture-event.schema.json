{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gmsd:aos:schema:capture-event:v1",
  "title": "AOS Capture Event (state/events.ndjson)",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "eventType",
    "timestampUtc",
    "todoId"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "eventType": {
      "type": "string",
      "const": "capture"
    },
    "timestampUtc": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the TODO was captured"
    },
    "todoId": {
      "type": "string",
      "description": "Reference to the captured TODO"
    },
    "source": {
      "type": "string",
      "description": "Origin context where the TODO was discovered"
    },
    "priority": {
      "type": "string",
      "enum": ["low", "medium", "high", "urgent"],
      "description": "Initial priority assessment"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "description": "Additional capture metadata"
    }
  }
}
