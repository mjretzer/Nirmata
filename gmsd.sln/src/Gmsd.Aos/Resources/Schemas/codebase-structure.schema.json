{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gmsd:aos:schema:codebase-structure:v1",
  "title": "Codebase Structure (structure.json)",
  "description": "Directory and file structure with metadata and statistics",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "directories",
    "files",
    "statistics"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "directories": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "name"
        ],
        "properties": {
          "path": {
            "type": "string",
            "description": "Relative path from repository root"
          },
          "name": {
            "type": "string",
            "description": "Directory name"
          },
          "parent": {
            "type": "string",
            "description": "Parent directory path"
          },
          "depth": {
            "type": "integer",
            "minimum": 0,
            "description": "Nesting depth from root"
          },
          "fileCount": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of files in this directory"
          },
          "subdirectoryCount": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of subdirectories"
          },
          "purpose": {
            "type": "string",
            "enum": ["source", "test", "config", "documentation", "build", "resources", "tools", "unknown"],
            "description": "Inferred directory purpose"
          }
        }
      }
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "name"
        ],
        "properties": {
          "path": {
            "type": "string",
            "description": "Relative path from repository root"
          },
          "name": {
            "type": "string",
            "description": "File name with extension"
          },
          "directory": {
            "type": "string",
            "description": "Parent directory path"
          },
          "extension": {
            "type": "string",
            "description": "File extension"
          },
          "type": {
            "type": "string",
            "enum": ["code", "test", "config", "documentation", "build", "resource", "data", "unknown"],
            "description": "Classified file type"
          },
          "language": {
            "type": "string",
            "description": "Programming language if code file"
          },
          "lines": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of lines in file"
          },
          "sizeBytes": {
            "type": "integer",
            "minimum": 0,
            "description": "File size in bytes"
          },
          "lastModified": {
            "type": "string",
            "format": "date-time",
            "description": "Last modification timestamp"
          },
          "hash": {
            "type": "string",
            "description": "Content hash for change detection"
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rootFiles": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Files in repository root"
        },
        "rootDirectories": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Top-level directories"
        },
        "ignoredPatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Patterns excluded from scan"
        }
      }
    },
    "statistics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "totalFiles",
        "totalDirectories",
        "totalLinesOfCode",
        "averageFileSize"
      ],
      "properties": {
        "totalFiles": {
          "type": "integer",
          "minimum": 0
        },
        "totalDirectories": {
          "type": "integer",
          "minimum": 0
        },
        "totalLinesOfCode": {
          "type": "integer",
          "minimum": 0
        },
        "averageFileSize": {
          "type": "number",
          "minimum": 0,
          "description": "Average file size in bytes"
        },
        "maxDirectoryDepth": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum nesting depth"
        },
        "filesByType": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          },
          "description": "Count of files by type classification"
        },
        "filesByExtension": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          },
          "description": "Count of files by extension"
        }
      }
    }
  }
}
