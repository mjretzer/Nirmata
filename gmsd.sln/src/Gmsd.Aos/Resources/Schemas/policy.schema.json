{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gmsd:aos:schema:policy:v1",
  "title": "AOS Policy (policy.json)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "scopeAllowlist",
    "toolAllowlist",
    "noImplicitState"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "scopeAllowlist": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "write"
      ],
      "properties": {
        "write": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "toolAllowlist": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tools",
        "providers"
      ],
      "properties": {
        "tools": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "providers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "noImplicitState": {
      "type": "boolean",
      "const": true
    }
  }
}

