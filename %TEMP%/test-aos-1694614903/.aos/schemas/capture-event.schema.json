{
  "$id": "gmsd:aos:schema:capture-event:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "eventType": {
      "const": "capture",
      "type": "string"
    },
    "metadata": {
      "additionalProperties": true,
      "description": "Additional capture metadata",
      "type": "object"
    },
    "priority": {
      "description": "Initial priority assessment",
      "enum": [
        "low",
        "medium",
        "high",
        "urgent"
      ],
      "type": "string"
    },
    "schemaVersion": {
      "const": 1,
      "type": "integer"
    },
    "source": {
      "description": "Origin context where the TODO was discovered",
      "type": "string"
    },
    "timestampUtc": {
      "description": "ISO 8601 timestamp when the TODO was captured",
      "format": "date-time",
      "type": "string"
    },
    "todoId": {
      "description": "Reference to the captured TODO",
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "eventType",
    "timestampUtc",
    "todoId"
  ],
  "title": "AOS Capture Event (state/events.ndjson)",
  "type": "object"
}
