{
  "$id": "gmsd:aos:schema:codebase-stack:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Technology stack detection including languages, frameworks, build tools, and package managers",
  "properties": {
    "buildTools": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "configurationFiles": {
            "description": "List of configuration file paths",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "name": {
            "description": "Build tool name (e.g., \u0027MSBuild\u0027, \u0027Vite\u0027, \u0027Webpack\u0027)",
            "type": "string"
          },
          "version": {
            "description": "Detected build tool version",
            "type": "string"
          }
        },
        "required": [
          "name"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "frameworks": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "name": {
            "description": "Framework name (e.g., \u0027.NET\u0027, \u0027React\u0027, \u0027ASP.NET Core\u0027)",
            "type": "string"
          },
          "type": {
            "description": "Framework category",
            "enum": [
              "frontend",
              "backend",
              "testing",
              "data",
              "utility"
            ],
            "type": "string"
          },
          "version": {
            "description": "Detected framework version",
            "type": "string"
          }
        },
        "required": [
          "name",
          "version"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "languages": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "fileCount": {
            "description": "Number of files in this language",
            "minimum": 0,
            "type": "integer"
          },
          "linesOfCode": {
            "description": "Total lines of code",
            "minimum": 0,
            "type": "integer"
          },
          "name": {
            "description": "Programming language name (e.g., \u0027C#\u0027, \u0027TypeScript\u0027)",
            "type": "string"
          },
          "percentage": {
            "description": "Percentage of codebase",
            "maximum": 100,
            "minimum": 0,
            "type": "number"
          },
          "version": {
            "description": "Detected language version",
            "type": "string"
          }
        },
        "required": [
          "name",
          "version"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "packageManagers": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "manifestFiles": {
            "description": "List of manifest file paths (e.g., package.json, .csproj)",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "name": {
            "description": "Package manager name (e.g., \u0027NuGet\u0027, \u0027npm\u0027, \u0027pip\u0027)",
            "type": "string"
          },
          "version": {
            "description": "Detected package manager version",
            "type": "string"
          }
        },
        "required": [
          "name"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "schemaVersion": {
      "const": 1,
      "type": "integer"
    }
  },
  "required": [
    "schemaVersion",
    "languages",
    "frameworks",
    "buildTools",
    "packageManagers"
  ],
  "title": "Codebase Stack (stack.json)",
  "type": "object"
}
