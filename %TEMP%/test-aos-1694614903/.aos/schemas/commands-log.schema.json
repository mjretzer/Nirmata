{
  "$id": "gmsd:aos:schema:commands-log:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "items": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "args": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "command": {
            "type": "string"
          },
          "exitCode": {
            "type": "integer"
          },
          "runId": {
            "pattern": "^[0-9a-f]{32}$",
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "command",
          "args",
          "exitCode",
          "runId"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "schemaVersion": {
      "const": 1,
      "type": "integer"
    }
  },
  "required": [
    "schemaVersion",
    "items"
  ],
  "title": "AOS Commands Log (.aos/evidence/logs/commands.json)",
  "type": "object"
}
