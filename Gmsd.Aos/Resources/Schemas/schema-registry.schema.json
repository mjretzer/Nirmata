{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gmsd:aos:schema:schema-registry:v1",
  "title": "AOS Schema Registry (registry.json)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "schemas"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "schemas": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}

