{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gmsd:aos:schema:roadmap:v1",
  "title": "AOS Roadmap Spec (roadmap.json)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "roadmap"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "roadmap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "items"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "title",
              "kind"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "kind": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}

