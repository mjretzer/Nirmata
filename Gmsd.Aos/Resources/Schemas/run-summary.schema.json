{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gmsd:aos:schema:run-summary:v1",
  "title": "AOS Run Summary (.aos/evidence/runs/<run-id>/summary.json)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "runId",
    "status",
    "startedAtUtc",
    "finishedAtUtc",
    "exitCode",
    "artifacts"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "runId": {
      "type": "string",
      "pattern": "^[0-9a-f]{32}$"
    },
    "status": {
      "type": "string"
    },
    "startedAtUtc": {
      "type": "string"
    },
    "finishedAtUtc": {
      "type": [
        "string",
        "null"
      ]
    },
    "exitCode": {
      "type": "integer"
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runMetadata",
        "packet",
        "result",
        "manifest",
        "commands",
        "logsRoot",
        "outputsRoot"
      ],
      "properties": {
        "runMetadata": {
          "type": "string"
        },
        "packet": {
          "type": "string"
        },
        "result": {
          "type": "string"
        },
        "manifest": {
          "type": "string"
        },
        "commands": {
          "type": "string"
        },
        "logsRoot": {
          "type": "string"
        },
        "outputsRoot": {
          "type": "string"
        }
      }
    }
  }
}

