{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gmsd:aos:schema:runs-index:v1",
  "title": "AOS Runs Index (runs/index.json)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "items"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "runId",
          "status",
          "startedAtUtc"
        ],
        "properties": {
          "runId": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "startedAtUtc": {
            "type": "string"
          },
          "finishedAtUtc": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    }
  }
}

