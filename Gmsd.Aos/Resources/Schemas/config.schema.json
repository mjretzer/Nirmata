{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gmsd:aos:schema:config:v1",
  "title": "AOS Config (config.json)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "secrets"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "secrets": {
      "type": "object",
      "additionalProperties": {
        "$ref": "gmsd:aos:schema:secret-ref:v1"
      }
    }
  }
}

