{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gmsd:aos:schema:codebase-map:v1",
  "title": "Codebase Map (map.json)",
  "description": "High-level codebase overview with repository metadata and summary statistics",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "version",
    "repository",
    "scanTimestamp",
    "summary"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "version": {
      "type": "string",
      "description": "Schema version identifier for the map format"
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "root",
        "name",
        "type"
      ],
      "properties": {
        "root": {
          "type": "string",
          "description": "Absolute path to repository root"
        },
        "name": {
          "type": "string",
          "description": "Repository name"
        },
        "type": {
          "type": "string",
          "enum": ["git", "svn", "mercurial", "none"],
          "description": "Version control system type"
        },
        "remoteUrl": {
          "type": "string",
          "description": "Primary remote repository URL"
        },
        "branch": {
          "type": "string",
          "description": "Current branch name"
        },
        "commit": {
          "type": "string",
          "description": "Current commit hash"
        }
      }
    },
    "scanTimestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the scan was performed"
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "totalFiles",
        "totalDirectories",
        "totalLinesOfCode",
        "projectCount"
      ],
      "properties": {
        "totalFiles": {
          "type": "integer",
          "minimum": 0
        },
        "totalDirectories": {
          "type": "integer",
          "minimum": 0
        },
        "totalLinesOfCode": {
          "type": "integer",
          "minimum": 0
        },
        "projectCount": {
          "type": "integer",
          "minimum": 0
        },
        "fileTypeBreakdown": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          },
          "description": "Count of files by extension/type"
        }
      }
    }
  }
}
