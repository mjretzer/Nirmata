{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nirmata:aos:schema:codebase-symbols:v1",
  "title": "Codebase Symbols Cache (cache/symbols.json)",
  "description": "Symbol index cache for fast lookup of types, methods, properties and their locations",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedAt",
    "symbols",
    "locations",
    "references"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the symbol cache was generated"
    },
    "symbols": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "kind",
          "namespace"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique symbol identifier"
          },
          "name": {
            "type": "string",
            "description": "Symbol name"
          },
          "kind": {
            "type": "string",
            "enum": ["namespace", "class", "interface", "struct", "enum", "delegate", "method", "property", "field", "event", "constructor", "operator", "indexer", "constant"],
            "description": "Symbol classification"
          },
          "namespace": {
            "type": "string",
            "description": "Containing namespace"
          },
          "declaringType": {
            "type": "string",
            "description": "For members, the containing type name"
          },
          "accessibility": {
            "type": "string",
            "enum": ["public", "internal", "protected", "private", "protected-internal", "private-protected"],
            "description": "Symbol accessibility modifier"
          },
          "signature": {
            "type": "string",
            "description": "Method/property signature for overload resolution"
          },
          "documentation": {
            "type": "string",
            "description": "XML documentation summary if available"
          },
          "attributes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Applied attributes"
          }
        }
      }
    },
    "locations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "symbolId",
          "filePath",
          "startLine",
          "startColumn"
        ],
        "properties": {
          "symbolId": {
            "type": "string",
            "description": "Reference to symbol id"
          },
          "filePath": {
            "type": "string",
            "description": "Absolute file path"
          },
          "startLine": {
            "type": "integer",
            "minimum": 1,
            "description": "1-based starting line number"
          },
          "startColumn": {
            "type": "integer",
            "minimum": 1,
            "description": "1-based starting column number"
          },
          "endLine": {
            "type": "integer",
            "minimum": 1,
            "description": "1-based ending line number"
          },
          "endColumn": {
            "type": "integer",
            "minimum": 1,
            "description": "1-based ending column number"
          }
        }
      }
    },
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "fromSymbolId",
          "toSymbolId"
        ],
        "properties": {
          "fromSymbolId": {
            "type": "string",
            "description": "Symbol that makes the reference"
          },
          "toSymbolId": {
            "type": "string",
            "description": "Symbol being referenced"
          },
          "referenceType": {
            "type": "string",
            "enum": ["invocation", "inheritance", "implementation", "usage", "declaration", "assignment"],
            "description": "Type of reference relationship"
          },
          "location": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "filePath",
              "line",
              "column"
            ],
            "properties": {
              "filePath": {
                "type": "string"
              },
              "line": {
                "type": "integer",
                "minimum": 1
              },
              "column": {
                "type": "integer",
                "minimum": 1
              }
            }
          }
        }
      }
    }
  }
}
