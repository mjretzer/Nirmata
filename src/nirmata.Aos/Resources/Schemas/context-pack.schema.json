{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nirmata:aos:schema:context-pack:v1",
  "title": "AOS Context Pack (context-pack.json)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "packId",
    "mode",
    "drivingId",
    "budget",
    "summary",
    "entries"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "packId": {
      "type": "string",
      "pattern": "^PCK-[0-9]{4}$"
    },
    "mode": {
      "type": "string",
      "enum": [
        "task",
        "phase"
      ]
    },
    "drivingId": {
      "type": "string"
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "maxBytes",
        "maxItems"
      ],
      "properties": {
        "maxBytes": {
          "type": "integer",
          "minimum": 0
        },
        "maxItems": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "totalBytes",
        "totalItems"
      ],
      "properties": {
        "totalBytes": {
          "type": "integer",
          "minimum": 0
        },
        "totalItems": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "contractPath",
          "contentType",
          "content",
          "sha256",
          "bytes"
        ],
        "properties": {
          "contractPath": {
            "type": "string",
            "minLength": 1,
            "pattern": "^\\.aos\\/[^\\\\]*$"
          },
          "contentType": {
            "type": "string",
            "minLength": 1
          },
          "content": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "bytes": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "required": [
          "mode"
        ],
        "properties": {
          "mode": {
            "const": "task"
          }
        }
      },
      "then": {
        "properties": {
          "drivingId": {
            "pattern": "^TSK-[0-9]{6}$"
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "mode"
        ],
        "properties": {
          "mode": {
            "const": "phase"
          }
        }
      },
      "then": {
        "properties": {
          "drivingId": {
            "pattern": "^PH-[0-9]{4}$"
          }
        }
      }
    }
  ]
}

