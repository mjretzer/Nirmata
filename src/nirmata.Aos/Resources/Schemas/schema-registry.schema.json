{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nirmata:aos:schema:schema-registry:v1",
  "title": "AOS Schema Registry (registry.json)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "schemas",
    "artifactContracts"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "schemas": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifactContracts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "schemaId",
          "currentVersion",
          "supportedVersions",
          "deprecatedVersions"
        ],
        "properties": {
          "schemaId": {
            "type": "string",
            "minLength": 1
          },
          "currentVersion": {
            "type": "integer",
            "minimum": 1
          },
          "supportedVersions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "integer",
              "minimum": 1
            }
          },
          "deprecatedVersions": {
            "type": "array",
            "items": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      }
    }
  }
}

