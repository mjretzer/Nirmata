{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nirmata:aos:schema:project:v1",
  "title": "AOS Project Spec (project.json)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "project"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    }
  }
}

