{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nirmata:aos:schema:phase-plan:v1",
  "title": "AOS Phase Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "planId",
    "phaseId",
    "tasks"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1,
      "description": "The schema version of this artifact."
    },
    "planId": {
      "type": "string",
      "description": "The unique identifier for this plan."
    },
    "phaseId": {
      "type": "string",
      "description": "The phase identifier this plan is for."
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "description",
          "fileScopes",
          "verificationSteps"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the task (e.g., TSK-001)."
          },
          "title": {
            "type": "string",
            "minLength": 5,
            "maxLength": 100
          },
          "description": {
            "type": "string",
            "minLength": 10
          },
          "fileScopes": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "path"
              ],
              "properties": {
                "path": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "verificationSteps": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
