@page
@model Gmsd.Web.Pages.Issues.IndexModel
@using Gmsd.Web.Models
@{
    ViewData["Title"] = "Issues";
}

<h1>Issues</h1>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-error">
        @Model.ErrorMessage
    </div>
}

@if (Model.Issues.Count == 0)
{
    <div class="empty-state">
        <div class="empty-state-icon">🐛</div>
        <h3>No Issues Found</h3>
        <p>There are no issues in the system yet.</p>
        <p class="text-muted">Issues are created automatically when UAT checks fail.</p>
        <a href="~/Uat" class="btn btn-secondary">Go to UAT</a>
    </div>
}
else
{
    <div class="filter-bar">
        <form method="get" class="filter-group">
            <label class="filter-label">Status:</label>
            <select name="FilterStatus" class="filter-select" onchange="this.form.submit()">
                <option value="">All Statuses</option>
                <option value="Open" selected="@(Model.FilterStatus == "Open" ? "selected" : null)">Open</option>
                <option value="InProgress" selected="@(Model.FilterStatus == "InProgress" ? "selected" : null)">In Progress</option>
                <option value="Resolved" selected="@(Model.FilterStatus == "Resolved" ? "selected" : null)">Resolved</option>
                <option value="Deferred" selected="@(Model.FilterStatus == "Deferred" ? "selected" : null)">Deferred</option>
                <option value="Closed" selected="@(Model.FilterStatus == "Closed" ? "selected" : null)">Closed</option>
            </select>
        </form>

        <form method="get" class="filter-group">
            <label class="filter-label">Severity:</label>
            <select name="FilterSeverity" class="filter-select" onchange="this.form.submit()">
                <option value="">All Severities</option>
                <option value="Critical" selected="@(Model.FilterSeverity == "Critical" ? "selected" : null)">Critical</option>
                <option value="High" selected="@(Model.FilterSeverity == "High" ? "selected" : null)">High</option>
                <option value="Medium" selected="@(Model.FilterSeverity == "Medium" ? "selected" : null)">Medium</option>
                <option value="Low" selected="@(Model.FilterSeverity == "Low" ? "selected" : null)">Low</option>
            </select>
        </form>

        <form method="get" class="filter-group">
            <label class="filter-label">Type:</label>
            <select name="FilterType" class="filter-select" onchange="this.form.submit()">
                <option value="">All Types</option>
                <option value="Bug" selected="@(Model.FilterType == "Bug" ? "selected" : null)">Bug</option>
                <option value="Task" selected="@(Model.FilterType == "Task" ? "selected" : null)">Task</option>
                <option value="Enhancement" selected="@(Model.FilterType == "Enhancement" ? "selected" : null)">Enhancement</option>
                <option value="Blocker" selected="@(Model.FilterType == "Blocker" ? "selected" : null)">Blocker</option>
            </select>
        </form>

        <form method="get" class="filter-group">
            <label class="filter-label">Task:</label>
            <select name="FilterTaskId" class="filter-select" onchange="this.form.submit()">
                <option value="">All Tasks</option>
                @foreach (var task in Model.Issues.Select(i => new { i.TaskId, i.TaskName }).Distinct().Where(t => !string.IsNullOrEmpty(t.TaskId)))
                {
                    <option value="@task.TaskId" selected="@(Model.FilterTaskId == task.TaskId ? "selected" : null)">@task.TaskName</option>
                }
            </select>
        </form>

        <form method="get" class="filter-group">
            <label class="filter-label">Phase:</label>
            <select name="FilterPhaseId" class="filter-select" onchange="this.form.submit()">
                <option value="">All Phases</option>
                @foreach (var phase in Model.Issues.Select(i => new { i.PhaseId, i.PhaseName }).Distinct().Where(p => !string.IsNullOrEmpty(p.PhaseId)))
                {
                    <option value="@phase.PhaseId" selected="@(Model.FilterPhaseId == phase.PhaseId ? "selected" : null)">@phase.PhaseName</option>
                }
            </select>
        </form>

        <form method="get" class="filter-group">
            <label class="filter-label">Milestone:</label>
            <select name="FilterMilestoneId" class="filter-select" onchange="this.form.submit()">
                <option value="">All Milestones</option>
                @foreach (var milestone in Model.Issues.Select(i => new { i.MilestoneId, i.MilestoneName }).Distinct().Where(m => !string.IsNullOrEmpty(m.MilestoneId)))
                {
                    <option value="@milestone.MilestoneId" selected="@(Model.FilterMilestoneId == milestone.MilestoneId ? "selected" : null)">@milestone.MilestoneName</option>
                }
            </select>
        </form>

        <form method="get" class="filter-group" style="flex: 1;">
            <div class="input-group">
                <input type="text" name="SearchQuery" class="form-control" 
                       placeholder="Search issues..." value="@Model.SearchQuery" />
                <button type="submit" class="btn btn-secondary">Search</button>
                @if (!string.IsNullOrEmpty(Model.SearchQuery) || !string.IsNullOrEmpty(Model.FilterStatus) || 
                     !string.IsNullOrEmpty(Model.FilterSeverity) || !string.IsNullOrEmpty(Model.FilterType) ||
                     !string.IsNullOrEmpty(Model.FilterTaskId) || !string.IsNullOrEmpty(Model.FilterPhaseId) ||
                     !string.IsNullOrEmpty(Model.FilterMilestoneId))
                {
                    <a href="~/Issues" class="btn btn-secondary">Clear</a>
                }
            </div>
        </form>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Type</th>
                <th>Severity</th>
                <th>Status</th>
                <th>Related To</th>
                <th>Created</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var issue in Model.Issues)
            {
                <tr>
                    <td><code>@issue.Id</code></td>
                    <td>
                        <strong>@issue.Title</strong>
                        @if (!string.IsNullOrEmpty(issue.TaskName))
                        {
                            <br /><small class="text-muted">Task: @issue.TaskName</small>
                        }
                    </td>
                    <td>
                        <span class="badge badge-@(issue.Type.ToString().ToLower())">
                            @issue.Type
                        </span>
                    </td>
                    <td>
                        @await Html.PartialAsync("_IssueSeverityBadge", issue.Severity)
                    </td>
                    <td>
                        @await Html.PartialAsync("_IssueStatusBadge", issue.Status)
                    </td>
                    <td>
                        @if (!string.IsNullOrEmpty(issue.UatSessionId))
                        {
                            <a href="~/Uat/Verify?taskId=@issue.TaskId&sessionId=@issue.UatSessionId" class="badge badge-info" title="UAT Session">
                                UAT
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(issue.TaskId))
                        {
                            <a href="~/Tasks/Details/@issue.TaskId" class="badge badge-secondary" title="Task">
                                Task
                            </a>
                        }
                    </td>
                    <td>
                        @if (issue.CreatedAt.HasValue)
                        {
                            @issue.CreatedAt.Value.ToString("yyyy-MM-dd")
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td>
                        <a href="~/Issues/Details/@issue.Id" class="btn btn-sm btn-primary">View</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="mt-3">
        <a href="~/Uat" class="btn btn-secondary">← Back to UAT</a>
        <a href="~/Tasks" class="btn btn-secondary">Tasks</a>
        <a href="~/Runs" class="btn btn-secondary">Runs</a>
    </div>
}
