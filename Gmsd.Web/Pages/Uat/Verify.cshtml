@page
@model Gmsd.Web.Pages.Uat.VerifyModel
@using Gmsd.Web.Models
@{
    ViewData["Title"] = $"Verify Work: {Model.TaskName}";
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-error">
        @Model.ErrorMessage
    </div>
}

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">
        @Model.SuccessMessage
    </div>
}

<div class="detail-page">
    <div class="detail-header">
        <div class="detail-title">
            <h1>🔍 Verify Work: @Model.TaskName</h1>
            <span class="badge @(Model.OverallStatus switch {
                "Passed" => "badge-success",
                "InProgress" => "badge-warning",
                "Failed" => "badge-error",
                _ => "badge-info"
            })">
                @Model.OverallStatus
            </span>
        </div>
        <div class="detail-meta">
            <span>Task ID: <code>@Model.TaskId</code></span>
            <span>Session: <code>@Model.SessionId</code></span>
            @if (Model.StartedAt.HasValue)
            {
                <span>Started: @Model.StartedAt.Value.ToString("yyyy-MM-dd HH:mm")</span>
            }
        </div>
        <div class="detail-actions">
            <a href="~/Uat" class="btn btn-secondary">← Back to UAT</a>
            <a href="~/Tasks/Details/@Model.TaskId" class="btn btn-secondary">View Task</a>
            <a href="~/Runs" class="btn btn-secondary">View Runs</a>
        </div>
    </div>

    @if (Model.Checks.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-state-icon">📝</div>
            <h3>No Acceptance Criteria</h3>
            <p>This task has no acceptance criteria defined for verification.</p>
            <a href="~/Tasks/Details/@Model.TaskId" class="btn btn-primary">Edit Task to Add Criteria</a>
        </div>
    }
    else
    {
        <div class="wizard-progress mb-3">
            <div class="progress-bar">
                <div class="progress-fill" style="width: @Model.ProgressPercent%"></div>
            </div>
            <div class="progress-stats">
                <span class="stat-pass">@Model.PassedCount passed</span>
                <span class="stat-fail">@Model.FailedCount failed</span>
                <span class="stat-pending">@Model.PendingCount remaining</span>
            </div>
        </div>

        <form method="post" id="verifyForm">
            <input type="hidden" name="TaskId" value="@Model.TaskId" />
            <input type="hidden" name="SessionId" value="@Model.SessionId" />

            <div class="wizard-checklist">
                @for (int i = 0; i < Model.Checks.Count; i++)
                {
                    var check = Model.Checks[i];
                    <div class="check-item @(check.Passed == true ? "check-passed" : check.Passed == false ? "check-failed" : "check-pending")" data-check-id="@check.Id">
                        <div class="check-header">
                            <span class="check-number">@(i + 1)</span>
                            <span class="check-status-icon">
                                @if (check.Passed == true)
                                {
                                    <span class="icon-pass">✓</span>
                                }
                                else if (check.Passed == false)
                                {
                                    <span class="icon-fail">✗</span>
                                }
                                else
                                {
                                    <span class="icon-pending">○</span>
                                }
                            </span>
                        </div>
                        
                        <div class="check-content">
                            <p class="check-description">@check.Description</p>
                            
                            @if (!string.IsNullOrEmpty(check.IssueId))
                            {
                                <div class="check-issue">
                                    <span class="badge badge-error">Issue: @check.IssueId</span>
                                    <a href="~/Issues/Details/@check.IssueId" class="btn btn-sm btn-secondary">View Issue</a>
                                </div>
                            }

                            @if (check.Passed == false && !string.IsNullOrEmpty(check.ReproNotes))
                            {
                                <div class="check-repro-notes">
                                    <strong>Repro Notes:</strong>
                                    <p>@check.ReproNotes</p>
                                </div>
                            }
                        </div>

                        <div class="check-actions">
                            @if (check.Passed == null)
                            {
                                <button type="submit" 
                                        formaction="~/Uat/Verify?handler=PassCheck&checkId=@check.Id" 
                                        class="btn btn-success btn-sm">
                                    ✓ Pass
                                </button>
                                <button type="button" 
                                        class="btn btn-error btn-sm" 
                                        onclick="showFailDialog('@check.Id')">
                                    ✗ Fail
                                </button>
                                <button type="submit" 
                                        formaction="~/Uat/Verify?handler=SkipCheck&checkId=@check.Id" 
                                        class="btn btn-secondary btn-sm">
                                    → Skip
                                </button>
                            }
                            else if (check.Passed == true)
                            {
                                <span class="check-result pass">Passed @(check.VerifiedAt?.ToString("HH:mm") ?? "")</span>
                                <button type="submit" 
                                        formaction="~/Uat/Verify?handler=ResetCheck&checkId=@check.Id" 
                                        class="btn btn-secondary btn-sm">
                                    ↺ Reset
                                </button>
                            }
                            else if (check.Passed == false)
                            {
                                <span class="check-result fail">Failed</span>
                                <button type="submit" 
                                        formaction="~/Uat/Verify?handler=ResetCheck&checkId=@check.Id" 
                                        class="btn btn-secondary btn-sm">
                                    ↺ Reset
                                </button>
                            }
                        </div>
                    </div>

                    @if (check.Passed == null)
                    {
                        <div class="fail-dialog" id="fail-dialog-@check.Id" style="display: none;">
                            <div class="dialog-content">
                                <h4>Record Failure for Check @(i + 1)</h4>
                                <div class="form-group">
                                    <label>Reproduction Notes (what went wrong):</label>
                                    <textarea name="ReproNotes_@check.Id" 
                                              class="form-control" 
                                              rows="3" 
                                              placeholder="Describe what failed and how to reproduce..."></textarea>
                                </div>
                                <div class="dialog-actions">
                                    <button type="submit" 
                                            formaction="~/Uat/Verify?handler=FailCheck&checkId=@check.Id" 
                                            class="btn btn-error">
                                        ✗ Record Failure
                                    </button>
                                    <button type="button" 
                                            class="btn btn-secondary" 
                                            onclick="hideFailDialog('@check.Id')">
                                        Cancel
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>

            <div class="wizard-actions mt-4">
                @if (Model.PendingCount == 0)
                {
                    if (Model.FailedCount > 0)
                    {
                        <div class="alert alert-error mb-3">
                            <strong>@Model.FailedCount check(s) failed.</strong>
                            <p>Issues have been created for failed checks. Review and fix before completing verification.</p>
                        </div>
                        <button type="submit" 
                                formaction="~/Uat/Verify?handler=CompleteVerification" 
                                class="btn btn-primary"
                                disabled>
                            Complete (Fix Issues First)
                        </button>
                    }
                    else
                    {
                        <div class="alert alert-success mb-3">
                            <strong>All checks passed!</strong>
                            <p>The task has been verified successfully.</p>
                        </div>
                        <button type="submit" 
                                formaction="~/Uat/Verify?handler=CompleteVerification" 
                                class="btn btn-success">
                            ✓ Complete Verification
                        </button>
                    }
                }
                else
                {
                    <button type="submit" 
                            formaction="~/Uat/Verify?handler=SaveProgress" 
                            class="btn btn-secondary">
                        Save Progress
                    </button>
                }

                <button type="submit" 
                        formaction="~/Uat/Verify?handler=RestartVerification" 
                        class="btn btn-secondary"
                        onclick="return confirm('Restart verification? All current results will be reset.');">
                    ↻ Restart
                </button>

                <a href="~/Uat" class="btn btn-secondary">Cancel</a>
            </div>
        </form>

        @if (!string.IsNullOrEmpty(Model.LatestRunId))
        {
            <div class="section-card mt-4">
                <div class="section-header">
                    <h3 class="section-title">Latest Run Evidence</h3>
                </div>
                <div class="section-content">
                    <p>Refer to the latest run for implementation evidence:</p>
                    <a href="~/Runs/Details/@Model.LatestRunId" class="btn btn-secondary">
                        View Run @Model.LatestRunId
                    </a>
                </div>
            </div>
        }
    }
</div>

@section Scripts {
    <script>
        function showFailDialog(checkId) {
            document.querySelectorAll('.fail-dialog').forEach(d => d.style.display = 'none');
            const dialog = document.getElementById('fail-dialog-' + checkId);
            if (dialog) {
                dialog.style.display = 'block';
                dialog.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        }

        function hideFailDialog(checkId) {
            const dialog = document.getElementById('fail-dialog-' + checkId);
            if (dialog) {
                dialog.style.display = 'none';
            }
        }
    </script>
}
