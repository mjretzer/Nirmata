@page
@model Gmsd.Web.Pages.Uat.IndexModel
@using Gmsd.Web.Models
@{
    ViewData["Title"] = "UAT Verification";
}

<h1>UAT Verification</h1>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-error">
        @Model.ErrorMessage
    </div>
}

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">
        @Model.SuccessMessage
    </div>
}

@if (Model.UatSessions.Count == 0)
{
    <div class="empty-state">
        <div class="empty-state-icon">✅</div>
        <h3>No UAT Sessions Found</h3>
        <p>There are no UAT verification sessions yet.</p>
        <a href="~/Tasks" class="btn btn-primary">Go to Tasks to Verify Work</a>
    </div>
}
else
{
    <div class="filter-bar">
        <form method="get" class="filter-group">
            <label class="filter-label">Status:</label>
            <select name="FilterStatus" class="filter-select" onchange="this.form.submit()">
                <option value="">All Statuses</option>
                <option value="Pending" selected="@(Model.FilterStatus == "Pending" ? "selected" : null)">Pending</option>
                <option value="InProgress" selected="@(Model.FilterStatus == "InProgress" ? "selected" : null)">In Progress</option>
                <option value="Passed" selected="@(Model.FilterStatus == "Passed" ? "selected" : null)">Passed</option>
                <option value="Failed" selected="@(Model.FilterStatus == "Failed" ? "selected" : null)">Failed</option>
            </select>
        </form>

        <form method="get" class="filter-group">
            <label class="filter-label">Task:</label>
            <select name="FilterTaskId" class="filter-select" onchange="this.form.submit()">
                <option value="">All Tasks</option>
                @foreach (var task in Model.UatSessions.Select(s => new { s.TaskId, s.TaskName }).Distinct())
                {
                    <option value="@task.TaskId" selected="@(Model.FilterTaskId == task.TaskId ? "selected" : null)">@task.TaskName</option>
                }
            </select>
        </form>

        <form method="get" class="filter-group" style="flex: 1;">
            <div class="input-group">
                <input type="text" name="SearchQuery" class="form-control" 
                       placeholder="Search UAT sessions..." value="@Model.SearchQuery" />
                <button type="submit" class="btn btn-secondary">Search</button>
                @if (!string.IsNullOrEmpty(Model.SearchQuery) || !string.IsNullOrEmpty(Model.FilterStatus) || !string.IsNullOrEmpty(Model.FilterTaskId))
                {
                    <a href="~/Uat" class="btn btn-secondary">Clear</a>
                }
            </div>
        </form>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Session ID</th>
                <th>Task</th>
                <th>Started</th>
                <th>Status</th>
                <th>Results</th>
                <th>Issues</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var session in Model.UatSessions)
            {
                <tr>
                    <td><code>@session.Id</code></td>
                    <td>
                        <strong>@session.TaskName</strong>
                        <br /><small class="text-muted">@session.TaskId</small>
                    </td>
                    <td>
                        @if (session.StartedAt != default)
                        {
                            @session.StartedAt.ToString("yyyy-MM-dd HH:mm")
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td>
                        @{
                            var sessionStatus = session.FailedCount > 0 ? "Failed" :
                                               session.PendingCount == 0 && session.PassedCount > 0 ? "Passed" :
                                               session.PassedCount > 0 ? "InProgress" : "Pending";
                        }
                        <span class="badge @(sessionStatus switch {
                            "Passed" => "badge-success",
                            "InProgress" => "badge-warning",
                            "Failed" => "badge-error",
                            _ => "badge-info"
                        })">
                            @sessionStatus
                        </span>
                    </td>
                    <td>
                        <div class="quick-stats-inline">
                            <span class="stat-pass">@session.PassedCount ✓</span>
                            <span class="stat-fail">@session.FailedCount ✗</span>
                            <span class="stat-pending">@session.PendingCount ⏳</span>
                        </div>
                    </td>
                    <td>
                        @if (session.RelatedIssueIds.Count > 0)
                        {
                            <a href="~/Issues?SearchQuery=@session.TaskId" class="badge badge-error" title="View related issues">
                                @session.RelatedIssueIds.Count issue@(session.RelatedIssueIds.Count == 1 ? "" : "s")
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td>
                        <a href="~/Uat/Verify?taskId=@session.TaskId&sessionId=@session.Id" class="btn btn-sm btn-primary">
                            @(session.PendingCount == 0 ? "Review" : "Continue")
                        </a>
                        <a href="~/Tasks/Details/@session.TaskId" class="btn btn-sm btn-secondary">Task</a>
                        @if (!string.IsNullOrEmpty(session.LatestRunId))
                        {
                            <a href="~/Runs/Details/@session.LatestRunId" class="btn btn-sm btn-secondary">Run</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="mt-3">
        <a href="~/Tasks" class="btn btn-secondary">← Back to Tasks</a>
        <a href="~/Roadmap" class="btn btn-secondary">Roadmap</a>
    </div>
}
