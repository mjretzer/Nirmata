@page
@model Gmsd.Web.Pages.Context.IndexModel
@{
    ViewData["Title"] = "Context Packs";
}

<h1>Context Packs</h1>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-error">
        @Model.ErrorMessage
    </div>
}

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">
        @Model.SuccessMessage
    </div>
}

@if (string.IsNullOrEmpty(Model.WorkspacePath))
{
    <div class="empty-state">
        <div class="empty-state-icon">📦</div>
        <h3>No Workspace Selected</h3>
        <p>Please select a workspace to view context packs.</p>
        <a href="~/Workspace" class="btn btn-primary">Select Workspace</a>
    </div>
}
else if (Model.ContextPacks.Count == 0)
{
    <div class="empty-state">
        <div class="empty-state-icon">📦</div>
        <h3>No Context Packs</h3>
        <p>There are no context packs in this workspace.</p>
        <p class="text-muted">Context packs are created when tasks or phases are executed.</p>
        <a href="~/Tasks" class="btn btn-secondary">View Tasks</a>
    </div>
}
else
{
    <div class="filter-bar">
        <form method="get" class="filter-group" style="flex: 1;">
            <div class="input-group">
                <input type="text" name="SearchQuery" class="form-control"
                       placeholder="Search packs..." value="@Model.SearchQuery" />
                <button type="submit" class="btn btn-secondary">Search</button>
                @if (!string.IsNullOrEmpty(Model.SearchQuery) || !string.IsNullOrEmpty(Model.FilterDrivingId))
                {
                    <a href="~/Context" class="btn btn-secondary">Clear</a>
                }
            </div>
        </form>
    </div>

    <div class="pack-grid">
        @foreach (var pack in Model.ContextPacks)
        {
            <div class="pack-card">
                <div class="pack-header">
                    <div class="pack-id">
                        <code>@pack.PackId</code>
                    </div>
                    <span class="badge badge-@GetModeBadgeClass(pack.Mode)">
                        @pack.Mode
                    </span>
                </div>

                <div class="pack-driving">
                    <small class="text-muted">Driving:</small>
                    <strong>@pack.DrivingId</strong>
                </div>

                <div class="pack-budget">
                    <div class="budget-row">
                        <span class="budget-label">Size:</span>
                        <span class="budget-value">@FormatBytes(pack.TotalBytes) / @FormatBytes(pack.MaxBytes)</span>
                    </div>
                    <div class="budget-bar">
                        <div class="budget-fill" style="width: @pack.UtilizationPercent%"
                             data-utilization="@pack.UtilizationPercent"></div>
                    </div>
                    <div class="budget-row">
                        <span class="budget-label">Items:</span>
                        <span class="budget-value">@pack.EntryCount / @pack.MaxItems</span>
                    </div>
                </div>

                <div class="pack-meta">
                    <small class="text-muted">Schema v@(pack.SchemaVersion)</small>
                </div>

                <div class="pack-actions">
                    <a href="~/Context/Details/@pack.PackId" class="btn btn-sm btn-primary">Show Pack</a>
                    <form method="post" asp-page-handler="BuildPack" class="inline-form">
                        <input type="hidden" name="drivingId" value="@pack.DrivingId" />
                        <button type="submit" class="btn btn-sm btn-secondary">Rebuild</button>
                    </form>
                </div>
            </div>
        }
    </div>

    <div class="mt-3">
        <a href="~/Dashboard" class="btn btn-secondary">← Back to Dashboard</a>
    </div>
}

@functions {
    string GetModeBadgeClass(string? mode) => mode?.ToLower() switch
    {
        "task" => "primary",
        "phase" => "info",
        "run" => "success",
        _ => "secondary"
    };

    string FormatBytes(int bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024} KB";
        return $"{bytes / (1024 * 1024)} MB";
    }
}

<style>
    .pack-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 1rem;
        margin: 1rem 0;
    }

    .pack-card {
        border: 1px solid var(--border-color, #ddd);
        border-radius: 8px;
        padding: 1rem;
        background: var(--card-bg, #fff);
    }

    .pack-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.5rem;
    }

    .pack-driving {
        margin-bottom: 0.75rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--border-color, #eee);
    }

    .pack-budget {
        margin-bottom: 0.75rem;
    }

    .budget-row {
        display: flex;
        justify-content: space-between;
        font-size: 0.875rem;
        margin-bottom: 0.25rem;
    }

    .budget-bar {
        height: 4px;
        background: var(--border-color, #eee);
        border-radius: 2px;
        margin: 0.5rem 0;
        overflow: hidden;
    }

    .budget-fill {
        height: 100%;
        background: var(--success-color, #28a745);
        border-radius: 2px;
        transition: width 0.3s ease;
    }

    .budget-fill[data-utilization^="8"],
    .budget-fill[data-utilization^="9"] {
        background: var(--warning-color, #ffc107);
    }

    .budget-fill[data-utilization="100"] {
        background: var(--danger-color, #dc3545);
    }

    .pack-meta {
        margin-bottom: 0.75rem;
    }

    .pack-actions {
        display: flex;
        gap: 0.5rem;
    }

    .inline-form {
        display: inline;
    }
</style>
