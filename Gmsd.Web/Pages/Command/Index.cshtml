@page
@model Gmsd.Web.Pages.Command.IndexModel
@{
    ViewData["Title"] = "Command Center";
}

<div class="command-center">
    <header class="command-header">
        <h1>Command Center</h1>
        <div class="command-meta">
            <span class="workspace-indicator" id="workspace-indicator">
                @if (!string.IsNullOrEmpty(Model.WorkspacePath))
                {
                    <span class="badge badge-success">Workspace: @Model.WorkspaceName</span>
                }
                else
                {
                    <span class="badge badge-warning">No workspace selected</span>
                }
            </span>
        </div>
    </header>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-error">
            <strong>Error:</strong> @Model.ErrorMessage
            <p><a href="~/Workspace" class="btn btn-primary">Select Workspace</a></p>
        </div>
    }

    <div class="chat-container" id="chat-container">
        <div class="message-thread" id="message-thread">
            @if (Model.Messages.Count == 0)
            {
                <div class="welcome-message">
                    <h2>Welcome to Command Center</h2>
                    <p>Type a command or use <code>/help</code> to see available commands.</p>
                    <div class="command-suggestions">
                        <button class="suggestion-btn" onclick="insertCommand('/status')">/status</button>
                        <button class="suggestion-btn" onclick="insertCommand('/validate')">/validate</button>
                        <button class="suggestion-btn" onclick="insertCommand('/init')">/init</button>
                    </div>
                </div>
            }
            else
            {
                @foreach (var message in Model.Messages)
                {
                    <div class="message @message.GetMessageClass()" data-message-id="@message.Id">
                        <div class="message-avatar">
                            @if (message.IsUser)
                            {
                                <span class="avatar-user">U</span>
                            }
                            else
                            {
                                <span class="avatar-system">AOS</span>
                            }
                        </div>
                        <div class="message-content">
                            <div class="message-header">
                                <span class="message-author">@(message.IsUser ? "You" : "AOS")</span>
                                <span class="message-time">@message.Timestamp.ToString("HH:mm")</span>
                            </div>
                            <div class="message-body">
                                @if (!string.IsNullOrEmpty(message.HtmlContent))
                                {
                                    @Html.Raw(message.HtmlContent)
                                }
                                else if (message.Type == MessageType.CommandResult && message.HasStructuredData)
                                {
                                    @Html.Raw(message.FormattedContent)
                                }
                                else
                                {
                                    <p>@message.Content</p>
                                }
                            </div>
                            @if (message.HasAttachments)
                            {
                                <div class="message-attachments">
                                    @foreach (var attachment in message.Attachments)
                                    {
                                        <a href="@attachment.Url" class="attachment-link" target="_blank">
                                            <span class="attachment-icon">@attachment.Icon</span>
                                            <span class="attachment-name">@attachment.Name</span>
                                        </a>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
            }
        </div>

        @if (!string.IsNullOrEmpty(Model.WorkspacePath))
        {
            <!-- Safety Rails Panel -->
            <div class="safety-rails-panel" id="safety-rails-panel">
                <div class="safety-rails-header" onclick="toggleSafetyRails()">
                    <span class="safety-rails-title">🔒 Safety Rails</span>
                    <span class="safety-rails-toggle" id="safety-rails-toggle">▼</span>
                </div>
                <div class="safety-rails-content" id="safety-rails-content">
                    @if (!string.IsNullOrEmpty(Model.SafetyRails.Scope))
                    {
                        <div class="safety-rails-section">
                            <span class="safety-label">Scope:</span>
                            <span class="safety-value">@Model.SafetyRails.Scope</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.SafetyRails.LastCommand))
                    {
                        <div class="safety-rails-section">
                            <span class="safety-label">Last Command:</span>
                            <span class="safety-value">@Model.SafetyRails.LastCommand</span>
                        </div>
                    }
                    @if (Model.SafetyRails.TouchedFiles.Any())
                    {
                        <div class="safety-rails-section">
                            <span class="safety-label">Touched Files (@Model.SafetyRails.TouchedFiles.Count):</span>
                            <ul class="touched-files-list">
                                @foreach (var file in Model.SafetyRails.TouchedFiles.Take(10))
                                {
                                    <li>@file</li>
                                }
                                @if (Model.SafetyRails.TouchedFiles.Count > 10)
                                {
                                    <li class="more-files">... and @(Model.SafetyRails.TouchedFiles.Count - 10) more</li>
                                }
                            </ul>
                        </div>
                    }
                    <div class="safety-rails-section">
                        <span class="safety-label">Limits:</span>
                        <span class="safety-value">Max @Model.SafetyRails.MaxFilesPerOperation files per operation</span>
                    </div>
                </div>
            </div>

            <!-- Evidence Files Section -->
            @if (Model.EvidenceFiles.Any())
            {
                <div class="evidence-files-panel" id="evidence-files-panel">
                    <div class="evidence-files-header" onclick="toggleEvidenceFiles()">
                        <span class="evidence-files-title">📋 Evidence Files (@Model.EvidenceFiles.Count)</span>
                        <span class="evidence-files-toggle" id="evidence-files-toggle">▼</span>
                    </div>
                    <div class="evidence-files-content" id="evidence-files-content">
                        <ul class="evidence-files-list">
                            @foreach (var file in Model.EvidenceFiles)
                            {
                                <li class="evidence-file-item">
                                    <a href="@file.Path" class="evidence-file-link" target="_blank">
                                        <span class="evidence-file-icon">📄</span>
                                        <div class="evidence-file-info">
                                            <span class="evidence-file-name">@file.Name</span>
                                            @if (!string.IsNullOrEmpty(file.CreatedAt))
                                            {
                                                <span class="evidence-file-date">@file.CreatedAt</span>
                                            }
                                        </div>
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            }
        }
    </div>

    <div class="command-input-area">
        <form method="post" asp-page-handler="SendCommand" class="command-form" id="command-form">
            @Html.AntiForgeryToken()
            <div class="input-wrapper">
                <div class="slash-hint" id="slash-hint" style="display: none;">
                    <div class="hint-content">
                        @foreach (var cmd in Model.AvailableCommands)
                        {
                            <div class="hint-item" data-command="@cmd.Command">
                                <code>@cmd.Command</code>
                                <span class="hint-description">@cmd.Description</span>
                            </div>
                        }
                    </div>
                </div>
                <input type="text"
                       id="command-input"
                       name="command"
                       class="command-input"
                       placeholder="Type a command (e.g., /status, /validate)..."
                       autocomplete="off"
                       value="@Model.CurrentCommand"
                       @(!string.IsNullOrEmpty(Model.ErrorMessage) ? "disabled" : "") />
                <button type="submit" class="btn btn-primary send-btn" @(string.IsNullOrEmpty(Model.ErrorMessage) ? "" : "disabled")>
                    Send
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function insertCommand(cmd) {
            const input = document.getElementById('command-input');
            input.value = cmd;
            input.focus();
        }

        document.addEventListener('DOMContentLoaded', function() {
            const messageThread = document.getElementById('message-thread');
            if (messageThread) {
                messageThread.scrollTop = messageThread.scrollHeight;
            }

            const input = document.getElementById('command-input');
            const hint = document.getElementById('slash-hint');

            input.addEventListener('input', function() {
                const value = this.value;
                if (value.startsWith('/')) {
                    const filter = value.toLowerCase();
                    const items = hint.querySelectorAll('.hint-item');
                    let visibleCount = 0;

                    items.forEach(function(item) {
                        const cmd = item.getAttribute('data-command').toLowerCase();
                        if (cmd.includes(filter)) {
                            item.style.display = 'block';
                            visibleCount++;
                        } else {
                            item.style.display = 'none';
                        }
                    });

                    hint.style.display = visibleCount > 0 ? 'block' : 'none';
                } else {
                    hint.style.display = 'none';
                }
            });

            input.addEventListener('keydown', function(e) {
                if (e.key === 'Escape') {
                    hint.style.display = 'none';
                    return;
                }

                const visibleItems = Array.from(hint.querySelectorAll('.hint-item')).filter(item => item.style.display !== 'none');
                if (visibleItems.length === 0) return;

                const activeItem = hint.querySelector('.hint-item.active');
                let currentIndex = activeItem ? visibleItems.indexOf(activeItem) : -1;

                if (e.key === 'ArrowDown') {
                    e.preventDefault();
                    if (activeItem) activeItem.classList.remove('active');
                    currentIndex = (currentIndex + 1) % visibleItems.length;
                    visibleItems[currentIndex].classList.add('active');
                } else if (e.key === 'ArrowUp') {
                    e.preventDefault();
                    if (activeItem) activeItem.classList.remove('active');
                    currentIndex = currentIndex <= 0 ? visibleItems.length - 1 : currentIndex - 1;
                    visibleItems[currentIndex].classList.add('active');
                } else if (e.key === 'Enter' || e.key === 'Tab') {
                    if (activeItem && hint.style.display !== 'none') {
                        e.preventDefault();
                        const cmd = activeItem.getAttribute('data-command');
                        input.value = cmd + ' ';
                        hint.style.display = 'none';
                        input.focus();
                    }
                }
            });

            hint.addEventListener('click', function(e) {
                const item = e.target.closest('.hint-item');
                if (item) {
                    const cmd = item.getAttribute('data-command');
                    input.value = cmd + ' ';
                    input.focus();
                    hint.style.display = 'none';
                }
            });

            document.addEventListener('click', function(e) {
                if (!e.target.closest('.input-wrapper')) {
                    hint.style.display = 'none';
                }
            });
        });

        function toggleSafetyRails() {
            const content = document.getElementById('safety-rails-content');
            const toggle = document.getElementById('safety-rails-toggle');
            if (content.style.display === 'none') {
                content.style.display = 'block';
                toggle.textContent = '▼';
            } else {
                content.style.display = 'none';
                toggle.textContent = '▶';
            }
        }

        function toggleEvidenceFiles() {
            const content = document.getElementById('evidence-files-content');
            const toggle = document.getElementById('evidence-files-toggle');
            if (content.style.display === 'none') {
                content.style.display = 'block';
                toggle.textContent = '▼';
            } else {
                content.style.display = 'none';
                toggle.textContent = '▶';
            }
        }
    </script>
}
