@model Gmsd.Web.Pages.Dashboard.IndexModel

<div class="dashboard-grid" id="dashboard-content"
     hx-get="@Url.Page("/Dashboard/Index", "Refresh")"
     hx-trigger="every 5s"
     hx-select="#dashboard-content">
    
    <!-- Cursor Card -->
    <div class="card cursor-card">
        <div class="card-header">
            <h3>Current Position</h3>
            @if (Model.State != null)
            {
                <span class="status-badge status-@Model.State.Status.ToLowerInvariant()">@Model.State.Status</span>
            }
            else
            {
                <span class="status-badge status-unknown">Unknown</span>
            }
        </div>
        <div class="card-body">
            <div class="cursor-display">
                @if (Model.State != null)
                {
                    <div class="cursor-path">@Model.State.GetCursorDisplay()</div>
                    <div class="cursor-details">
                        @if (!string.IsNullOrEmpty(Model.State.MilestoneId))
                        {
                            <div class="cursor-item">
                                <span class="cursor-label">Milestone:</span>
                                <span class="cursor-value">@Model.State.MilestoneId</span>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.State.PhaseId))
                        {
                            <div class="cursor-item">
                                <span class="cursor-label">Phase:</span>
                                <span class="cursor-value">@Model.State.PhaseId</span>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.State.TaskId))
                        {
                            <div class="cursor-item">
                                <span class="cursor-label">Task:</span>
                                <span class="cursor-value">@Model.State.TaskId</span>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.State.StepId))
                        {
                            <div class="cursor-item">
                                <span class="cursor-label">Step:</span>
                                <span class="cursor-value">@Model.State.StepId</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <p>No state data available</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Blockers Card -->
    <div class="card blockers-card">
        <div class="card-header">
            <h3>Blockers</h3>
            <span class="badge">@Model.Blockers.Count</span>
        </div>
        <div class="card-body">
            @if (Model.Blockers.Count == 0)
            {
                <div class="empty-state">
                    <p>No active blockers. Workspace is clear!</p>
                </div>
            }
            else
            {
                <div class="blocker-list">
                    @foreach (var blocker in Model.Blockers)
                    {
                        <div class="blocker-item @blocker.GetSeverityClass()">
                            <div class="blocker-header">
                                <span class="blocker-id">#@blocker.Id</span>
                                <span class="severity-badge @blocker.GetSeverityClass()">@blocker.Severity</span>
                            </div>
                            <div class="blocker-title">@blocker.Title</div>
                            @if (!string.IsNullOrEmpty(blocker.Description))
                            {
                                <div class="blocker-description">@blocker.Description</div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- Quick Actions Card -->
    <div class="card actions-card">
        <div class="card-header">
            <h3>Quick Actions</h3>
        </div>
        <div class="card-body">
            <div class="quick-actions-grid">
                @foreach (var action in Model.QuickActions)
                {
                    <form method="post" asp-page-handler="@action.Action" class="action-form"
                          hx-post="@Url.Page("/Dashboard/Index", action.Action)"
                          hx-target="#dashboard-content"
                          hx-swap="outerHTML">
                        <button type="submit" class="btn btn-action">
                            <span class="action-icon">@GetActionIcon(action.Icon)</span>
                            <span class="action-label">@action.Label</span>
                            <span class="action-description">@action.Description</span>
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>

    <!-- Latest Run Card -->
    <div class="card run-card">
        <div class="card-header">
            <h3>Latest Run</h3>
        </div>
        <div class="card-body">
            @if (Model.LatestRun == null)
            {
                <div class="empty-state">
                    <p>No runs recorded yet.</p>
                </div>
            }
            else
            {
                <div class="run-summary">
                    <div class="run-header">
                        <span class="run-id">@Model.LatestRun.RunId</span>
                        <span class="status-badge @Model.LatestRun.GetStatusBadgeClass()">
                            @(Model.LatestRun.Success ? "Success" : Model.LatestRun.Status)
                        </span>
                    </div>
                    <div class="run-details">
                        @if (!string.IsNullOrEmpty(Model.LatestRun.StartedAt))
                        {
                            <div class="run-detail">
                                <span class="detail-label">Started:</span>
                                <span class="detail-value">@Model.LatestRun.StartedAt</span>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.LatestRun.CompletedAt))
                        {
                            <div class="run-detail">
                                <span class="detail-label">Completed:</span>
                                <span class="detail-value">@Model.LatestRun.CompletedAt</span>
                            </div>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(Model.LatestRun.EvidencePath))
                    {
                        <div class="run-actions">
                            <a href="@Url.Content(Model.LatestRun.EvidencePath)" class="btn btn-link">View Details</a>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@functions {
    private static string GetActionIcon(string icon)
    {
        return icon.ToLowerInvariant() switch
        {
            "check" => "✓",
            "save" => "💾",
            "pause" => "⏸",
            "play" => "▶",
            _ => "•"
        };
    }
}
