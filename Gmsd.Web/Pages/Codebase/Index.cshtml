@page
@model Gmsd.Web.Pages.Codebase.IndexModel
@{
    ViewData["Title"] = "Codebase Intelligence";
}

<h1>Codebase Intelligence</h1>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-error">
        @Model.ErrorMessage
    </div>
}

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">
        @Model.SuccessMessage
    </div>
}

@if (string.IsNullOrEmpty(Model.WorkspacePath))
{
    <div class="empty-state">
        <div class="empty-state-icon">📁</div>
        <h3>No Workspace Selected</h3>
        <p>Please select a workspace to view codebase intelligence.</p>
        <a href="~/Workspace" class="btn btn-primary">Select Workspace</a>
    </div>
}
else
{
    <!-- Status Overview -->
    <div class="dashboard-card mb-4">
        <div class="dashboard-header">
            <h2>Status Overview</h2>
        </div>
        <div class="dashboard-body">
            @if (Model.Status != null)
            {
                <div class="status-bar @GetStatusClass(Model.Status.OverallStatus)">
                    <div class="status-indicator"></div>
                    <div class="status-content">
                        <strong>@Model.Status.OverallStatus</strong>
                        <span class="text-muted"> - @Model.Status.StatusMessage</span>
                    </div>
                </div>

                <div class="stats-grid mt-3">
                    <div class="stat-item">
                        <div class="stat-value">@Model.Status.TotalArtifacts</div>
                        <div class="stat-label">Total Artifacts</div>
                    </div>
                    <div class="stat-item stat-valid">
                        <div class="stat-value">@Model.Status.ValidArtifacts</div>
                        <div class="stat-label">Valid</div>
                    </div>
                    <div class="stat-item stat-invalid">
                        <div class="stat-value">@Model.Status.InvalidArtifacts</div>
                        <div class="stat-label">Invalid</div>
                    </div>
                    <div class="stat-item stat-missing">
                        <div class="stat-value">@Model.Status.MissingArtifacts</div>
                        <div class="stat-label">Missing</div>
                    </div>
                </div>

                @if (Model.Status.LastScanAt.HasValue)
                {
                    <div class="mt-3 text-muted">
                        <small>Last updated: @Model.Status.LastScanAt.Value.ToString("yyyy-MM-dd HH:mm:ss")</small>
                    </div>
                }
            }
        </div>
    </div>

    <!-- Trigger Actions -->
    <div class="dashboard-card mb-4">
        <div class="dashboard-header">
            <h2>Actions</h2>
        </div>
        <div class="dashboard-body">
            <div class="action-buttons">
                <form method="post" asp-page-handler="Scan" class="d-inline">
                    <button type="submit" class="btn btn-primary @GetButtonActiveClass(Model.ActiveAction, "Scan")" @(Model.Status?.OverallStatus == "Scanning" ? "disabled" : "")>
                        <span class="btn-icon">🔍</span> Scan
                    </button>
                </form>
                <form method="post" asp-page-handler="BuildMap" class="d-inline">
                    <button type="submit" class="btn btn-secondary @GetButtonActiveClass(Model.ActiveAction, "Map")">
                        <span class="btn-icon">🗺️</span> Map Build
                    </button>
                </form>
                <form method="post" asp-page-handler="BuildSymbols" class="d-inline">
                    <button type="submit" class="btn btn-secondary @GetButtonActiveClass(Model.ActiveAction, "Symbols")">
                        <span class="btn-icon">🏷️</span> Symbols Build
                    </button>
                </form>
                <form method="post" asp-page-handler="BuildGraph" class="d-inline">
                    <button type="submit" class="btn btn-secondary @GetButtonActiveClass(Model.ActiveAction, "Graph")">
                        <span class="btn-icon">🕸️</span> Graph Build
                    </button>
                </form>
            </div>
            <p class="text-muted mt-2">
                <small>
                    <strong>Scan</strong> - Indexes all files and builds the foundation<br>
                    <strong>Map Build</strong> - Creates structure and organization map<br>
                    <strong>Symbols Build</strong> - Extracts and indexes code symbols<br>
                    <strong>Graph Build</strong> - Generates dependency and call graphs
                </small>
            </p>
        </div>
    </div>

    <!-- Artifacts Grid -->
    <div class="dashboard-card">
        <div class="dashboard-header">
            <h2>Intelligence Artifacts</h2>
        </div>
        <div class="dashboard-body">
            @if (Model.Artifacts.Count == 0)
            {
                <div class="empty-state">
                    <div class="empty-state-icon">📊</div>
                    <h3>No Artifacts</h3>
                    <p>No codebase intelligence artifacts have been generated yet.</p>
                    <p class="text-muted">Run a scan or build operation to create artifacts.</p>
                </div>
            }
            else
            {
                <div class="artifact-grid">
                    @foreach (var artifact in Model.Artifacts)
                    {
                        <div class="artifact-card @GetArtifactStatusClass(artifact)">
                            <div class="artifact-header">
                                <h4>@artifact.Name</h4>
                                <span class="badge @GetBadgeClass(artifact)">
                                    @GetArtifactStatusText(artifact)
                                </span>
                            </div>
                            <div class="artifact-body">
                                <p class="artifact-description">@artifact.Description</p>

                                @if (artifact.Exists)
                                {
                                    <div class="artifact-meta">
                                        @if (artifact.LastModified.HasValue)
                                        {
                                            <div class="meta-item">
                                                <span class="meta-label">Built:</span>
                                                <span class="meta-value">@artifact.LastModified.Value.ToString("yyyy-MM-dd HH:mm")</span>
                                            </div>
                                        }
                                        @if (!artifact.IsValid && !string.IsNullOrEmpty(artifact.ValidationError))
                                        {
                                            <div class="meta-item meta-error">
                                                <span class="meta-label">Error:</span>
                                                <span class="meta-value">@artifact.ValidationError</span>
                                            </div>
                                        }
                                    </div>

                                    <div class="artifact-actions mt-2">
                                        <a href="?ViewArtifact=@artifact.Id" class="btn btn-sm btn-primary">View</a>
                                        @if (artifact.FullPath != null && System.IO.File.Exists(artifact.FullPath))
                                        {
                                            <a href="data:application/json;base64,@Convert.ToBase64String(System.IO.File.ReadAllBytes(artifact.FullPath))"
                                               download="@artifact.FileName"
                                               class="btn btn-sm btn-secondary">Download</a>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="artifact-not-built">
                                        <span class="text-muted">Not yet built</span>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- Artifact Viewer Modal -->
    @if (!string.IsNullOrEmpty(Model.ViewArtifact))
    {
        var selectedArtifact = Model.Artifacts.FirstOrDefault(a => a.Id == Model.ViewArtifact);
        if (selectedArtifact != null && selectedArtifact.Exists && selectedArtifact.FullPath != null)
        {
            <div class="modal-overlay" id="artifactModal">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h3>@selectedArtifact.Name Artifact</h3>
                            <a href="~/Codebase" class="modal-close">&times;</a>
                        </div>
                        <div class="modal-body">
                            <div class="artifact-info mb-3">
                                <p><strong>File:</strong> @selectedArtifact.FileName</p>
                                <p><strong>Description:</strong> @selectedArtifact.Description</p>
                                @if (selectedArtifact.LastModified.HasValue)
                                {
                                    <p><strong>Last Modified:</strong> @selectedArtifact.LastModified.Value.ToString("yyyy-MM-dd HH:mm:ss")</p>
                                }
                                <p><strong>Status:</strong>
                                    <span class="badge @GetBadgeClass(selectedArtifact)">
                                        @GetArtifactStatusText(selectedArtifact)
                                    </span>
                                </p>
                            </div>

                            @if (System.IO.File.Exists(selectedArtifact.FullPath))
                            {
                                var content = System.IO.File.ReadAllText(selectedArtifact.FullPath);
                                @await Html.PartialAsync("Shared/_JsonViewer", new Gmsd.Web.Models.JsonViewerModel
                                {
                                    JsonContent = content,
                                    FileName = selectedArtifact.FileName,
                                    ShowToolbar = true,
                                    AllowDownload = true,
                                    DownloadUrl = $"data:application/json;base64,{Convert.ToBase64String(System.IO.File.ReadAllBytes(selectedArtifact.FullPath))}"
                                })
                            }
                        </div>
                        <div class="modal-footer">
                            <a href="~/Codebase" class="btn btn-secondary">Close</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    }

    <div class="mt-3">
        <a href="~/" class="btn btn-secondary">← Back to Dashboard</a>
    </div>
}

@functions {
    string GetStatusClass(string status) => status?.ToLower() switch
    {
        "ready" => "status-ready",
        "partial" => "status-partial",
        "degraded" => "status-degraded",
        "notinitialized" => "status-uninitialized",
        _ => "status-unknown"
    };

    string GetArtifactStatusClass(CodebaseArtifactViewModel artifact)
    {
        if (!artifact.Exists) return "artifact-missing";
        if (!artifact.IsValid) return "artifact-invalid";
        return "artifact-ready";
    }

    string GetArtifactStatusText(CodebaseArtifactViewModel artifact)
    {
        if (!artifact.Exists) return "Missing";
        if (!artifact.IsValid) return "Invalid";
        return "Ready";
    }

    string GetBadgeClass(CodebaseArtifactViewModel artifact)
    {
        if (!artifact.Exists) return "badge-secondary";
        if (!artifact.IsValid) return "badge-danger";
        return "badge-success";
    }

    string GetButtonActiveClass(string? activeAction, string buttonAction)
    {
        return activeAction == buttonAction ? "btn-active" : "";
    }
}

<style>
    .dashboard-card {
        background: var(--card-bg, #fff);
        border: 1px solid var(--border-color, #e1e4e8);
        border-radius: 6px;
        margin-bottom: 1rem;
    }

    .dashboard-header {
        padding: 1rem;
        border-bottom: 1px solid var(--border-color, #e1e4e8);
        background: var(--header-bg, #f6f8fa);
    }

    .dashboard-header h2 {
        margin: 0;
        font-size: 1.25rem;
    }

    .dashboard-body {
        padding: 1rem;
    }

    .status-bar {
        display: flex;
        align-items: center;
        padding: 0.75rem 1rem;
        border-radius: 6px;
        margin-bottom: 1rem;
    }

    .status-indicator {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        margin-right: 0.75rem;
    }

    .status-ready {
        background: #d4edda;
        border: 1px solid #c3e6cb;
    }
    .status-ready .status-indicator {
        background: #28a745;
    }

    .status-partial {
        background: #fff3cd;
        border: 1px solid #ffeeba;
    }
    .status-partial .status-indicator {
        background: #ffc107;
    }

    .status-degraded {
        background: #f8d7da;
        border: 1px solid #f5c6cb;
    }
    .status-degraded .status-indicator {
        background: #dc3545;
    }

    .status-uninitialized {
        background: #e2e3e5;
        border: 1px solid #d6d8db;
    }
    .status-uninitialized .status-indicator {
        background: #6c757d;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
        gap: 1rem;
    }

    .stat-item {
        text-align: center;
        padding: 0.75rem;
        background: var(--stat-bg, #f8f9fa);
        border-radius: 4px;
    }

    .stat-value {
        font-size: 1.5rem;
        font-weight: bold;
    }

    .stat-label {
        font-size: 0.875rem;
        color: var(--text-muted, #6c757d);
    }

    .stat-valid .stat-value {
        color: #28a745;
    }

    .stat-invalid .stat-value {
        color: #dc3545;
    }

    .stat-missing .stat-value {
        color: #6c757d;
    }

    .action-buttons {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .action-buttons form {
        display: inline;
    }

    .btn-active {
        box-shadow: 0 0 0 3px rgba(0, 123, 255, 0.5);
    }

    .artifact-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 1rem;
    }

    .artifact-card {
        border: 1px solid var(--border-color, #e1e4e8);
        border-radius: 6px;
        padding: 1rem;
        transition: box-shadow 0.2s;
    }

    .artifact-card:hover {
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .artifact-ready {
        border-left: 4px solid #28a745;
    }

    .artifact-invalid {
        border-left: 4px solid #dc3545;
    }

    .artifact-missing {
        border-left: 4px solid #6c757d;
        opacity: 0.7;
    }

    .artifact-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.75rem;
    }

    .artifact-header h4 {
        margin: 0;
        font-size: 1.1rem;
    }

    .artifact-description {
        color: var(--text-muted, #6c757d);
        font-size: 0.875rem;
        margin-bottom: 0.75rem;
    }

    .artifact-meta {
        font-size: 0.875rem;
    }

    .meta-item {
        margin-bottom: 0.25rem;
    }

    .meta-label {
        color: var(--text-muted, #6c757d);
    }

    .meta-error .meta-value {
        color: #dc3545;
    }

    .artifact-not-built {
        font-style: italic;
        color: var(--text-muted, #6c757d);
        padding: 0.5rem 0;
    }

    .artifact-actions {
        display: flex;
        gap: 0.5rem;
    }

    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }

    .modal-dialog {
        background: var(--card-bg, #fff);
        border-radius: 6px;
        max-width: 90vw;
        max-height: 90vh;
        overflow: auto;
    }

    .modal-lg {
        width: 900px;
    }

    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem;
        border-bottom: 1px solid var(--border-color, #e1e4e8);
    }

    .modal-header h3 {
        margin: 0;
    }

    .modal-close {
        font-size: 1.5rem;
        text-decoration: none;
        color: var(--text-muted, #6c757d);
    }

    .modal-body {
        padding: 1rem;
        max-height: 70vh;
        overflow-y: auto;
    }

    .modal-footer {
        padding: 1rem;
        border-top: 1px solid var(--border-color, #e1e4e8);
        text-align: right;
    }

    .artifact-info {
        background: var(--info-bg, #f8f9fa);
        padding: 0.75rem;
        border-radius: 4px;
    }

    .artifact-info p {
        margin: 0.25rem 0;
    }

    .d-inline {
        display: inline;
    }
</style>
