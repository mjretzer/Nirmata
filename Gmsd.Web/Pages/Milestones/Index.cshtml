@page
@model Gmsd.Web.Pages.Milestones.IndexModel
@using Gmsd.Web.Models
@{
    ViewData["Title"] = "Milestones";
}

<h1>Milestones</h1>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-error">
        @Model.ErrorMessage
    </div>
}

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">
        @Model.SuccessMessage
    </div>
}

@if (Model.Milestones.Count == 0)
{
    <div class="empty-state">
        <div class="empty-state-icon">🎯</div>
        <h3>No Milestones Found</h3>
        <p>There are no milestones defined in the roadmap yet.</p>
    </div>
}
else
{
    <div class="section-card mb-3">
        <div class="section-header">
            <h3 class="section-title">Create New Milestone</h3>
        </div>
        <div class="section-content">
            <form method="post" asp-page-handler="Create">
                <div class="input-group">
                    <input type="text" name="NewMilestoneName" class="form-control" 
                           placeholder="Milestone name..." required maxlength="100" />
                    <input type="text" name="NewMilestoneDescription" class="form-control" 
                           placeholder="Description (optional)..." maxlength="200" />
                    <input type="date" name="NewMilestoneTargetDate" class="form-control" 
                           placeholder="Target date" />
                    <button type="submit" class="btn btn-primary">Create Milestone</button>
                </div>
            </form>
        </div>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Status</th>
                <th>Progress</th>
                <th>Phases</th>
                <th>Target Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var milestone in Model.Milestones)
            {
                <tr>
                    <td>
                        <strong>@milestone.Name</strong>
                        @if (!string.IsNullOrEmpty(milestone.Description))
                        {
                            <br /><small class="text-muted">@milestone.Description</small>
                        }
                    </td>
                    <td>
                        <span class="badge @(milestone.Status switch {
                            SpecItemStatus.Completed or SpecItemStatus.Verified => "badge-success",
                            SpecItemStatus.InProgress => "badge-warning",
                            SpecItemStatus.Blocked => "badge-error",
                            SpecItemStatus.Draft => "badge-info",
                            _ => "badge-info"
                        })">
                            @milestone.Status
                        </span>
                    </td>
                    <td>
                        <div class="progress-bar" style="width: 100px; display: inline-block;">
                            <div class="progress-fill" style="width: @milestone.ProgressPercent%"></div>
                        </div>
                        <span class="text-muted">@milestone.ProgressPercent%</span>
                    </td>
                    <td>@milestone.Phases.Count</td>
                    <td>
                        @if (milestone.TargetDate.HasValue)
                        {
                            @milestone.TargetDate.Value.ToString("MMM dd, yyyy")
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td>
                        <a href="~/Milestones/Details/@milestone.Id" class="btn btn-sm btn-secondary">View</a>
                        @if (milestone.HasCompletionGate)
                        {
                            <span class="badge badge-success" title="@milestone.GateValidationMessage">✓ Gate</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="mt-3">
    <a href="~/Roadmap" class="btn btn-secondary">← Back to Roadmap</a>
</div>
