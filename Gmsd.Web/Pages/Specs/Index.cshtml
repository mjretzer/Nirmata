@page
@model Gmsd.Web.Pages.Specs.IndexModel
@{
    ViewData["Title"] = "Specs Explorer";
}

<div class="specs-explorer">
    <header class="specs-header">
        <h1>Specs Explorer</h1>
        <div class="specs-meta">
            @if (!string.IsNullOrEmpty(Model.WorkspacePath))
            {
                <span class="badge badge-success">@Model.WorkspaceName</span>
            }
            else
            {
                <span class="badge badge-warning">No workspace selected</span>
            }
        </div>
    </header>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-error">
            <strong>Error:</strong> @Model.ErrorMessage
            <p><a href="~/Workspace" class="btn btn-primary">Select Workspace</a></p>
        </div>
    }
    else if (string.IsNullOrEmpty(Model.WorkspacePath))
    {
        <div class="alert alert-info">
            <p>No workspace selected. Please select a workspace to browse specs.</p>
            <a href="~/Workspace" class="btn btn-primary">Select Workspace</a>
        </div>
    }
    else
    {
        <div class="specs-container">
            <!-- Search Bar -->
            <div class="search-bar">
                <form method="get" class="search-form">
                    <div class="input-group">
                        <input type="text"
                               name="search"
                               class="form-control"
                               placeholder="Search specs by filename or content..."
                               value="@Model.SearchQuery" />
                        <button type="submit" class="btn btn-primary">🔍 Search</button>
                        @if (!string.IsNullOrEmpty(Model.SearchQuery))
                        {
                            <a href="~/Specs" class="btn btn-secondary">Clear</a>
                        }
                    </div>
                </form>
            </div>

            <div class="specs-content">
                <!-- Tree View Sidebar -->
                <div class="tree-sidebar">
                    <div class="tree-header">
                        <h3>📁 Spec Tree</h3>
                        <button type="button" class="btn btn-sm btn-secondary" onclick="expandAll()">Expand</button>
                        <button type="button" class="btn btn-sm btn-secondary" onclick="collapseAll()">Collapse</button>
                    </div>
                    <div class="tree-content" id="tree-content">
                        @if (Model.SpecTree != null)
                        {
                            <partial name="_SpecTreeNode" model="Model.SpecTree" />
                        }
                        else
                        {
                            <p class="text-muted">No spec files found.</p>
                        }
                    </div>
                </div>

                <!-- Main Content Area -->
                <div class="specs-main">
                    @if (!string.IsNullOrEmpty(Model.SearchQuery))
                    {
                        <!-- Search Results -->
                        <div class="search-results">
                            <h3>Search Results for "@Model.SearchQuery"</h3>
                            @if (Model.SearchResults.Any())
                            {
                                <div class="results-list">
                                    @foreach (var result in Model.SearchResults)
                                    {
                                        <div class="result-item">
                                            <div class="result-header">
                                                <span class="result-icon">📄</span>
                                                <a href="~/Specs/View/@result.RelativePath" class="result-link">
                                                    @result.RelativePath
                                                </a>
                                            </div>
                                            @if (!string.IsNullOrEmpty(result.MatchingContent))
                                            {
                                                <div class="result-snippet">
                                                    @result.MatchingContent
                                                </div>
                                            }
                                            <div class="result-meta">
                                                <span>Type: @result.FileType</span>
                                                <span>Modified: @result.LastModified.ToString("MMM dd, yyyy HH:mm")</span>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="empty-state">
                                    <p>No results found for "@Model.SearchQuery"</p>
                                </div>
                            }
                        </div>
                    }
                    @if (Model.SelectedFile != null)
                    {
                        <!-- Redirect to View page -->
                        <script>
                            window.location.href = '@Url.Page("/Specs/View", new { path = Model.SelectedFile.RelativePath })';
                        </script>
                    }
                    else
                    {
                        <!-- Default View -->
                        <div class="welcome-panel">
                            <h3>Specs Explorer</h3>
                            <p>Browse and edit your AOS specification files.</p>
                            <div class="quick-stats">
                                <div class="stat-card">
                                    <span class="stat-value">@Model.TotalFiles</span>
                                    <span class="stat-label">Total Files</span>
                                </div>
                                <div class="stat-card">
                                    <span class="stat-value">@Model.SpecCategories.Count</span>
                                    <span class="stat-label">Categories</span>
                                </div>
                            </div>
                            <div class="category-list">
                                @foreach (var category in Model.SpecCategories)
                                {
                                    <div class="category-item">
                                        <span class="category-icon">📁</span>
                                        <span class="category-name">@category.Name</span>
                                        <span class="category-count">@category.FileCount files</span>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        function toggleNode(nodeId) {
            const node = document.getElementById('node-children-' + nodeId);
            const icon = document.getElementById('node-icon-' + nodeId);
            if (node) {
                if (node.style.display === 'none') {
                    node.style.display = 'block';
                    icon.textContent = '📂';
                } else {
                    node.style.display = 'none';
                    icon.textContent = '📁';
                }
            }
        }

        function expandAll() {
            document.querySelectorAll('.tree-children').forEach(node => {
                node.style.display = 'block';
            });
            document.querySelectorAll('.folder-icon').forEach(icon => {
                icon.textContent = '📂';
            });
        }

        function collapseAll() {
            document.querySelectorAll('.tree-children').forEach(node => {
                node.style.display = 'none';
            });
            document.querySelectorAll('.folder-icon').forEach(icon => {
                icon.textContent = '📁';
            });
        }
    </script>
}
