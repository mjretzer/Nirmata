@page
@model Gmsd.Web.Pages.Phases.IndexModel
@using Gmsd.Web.Models
@{
    ViewData["Title"] = "Phases";
}

<h1>Phases</h1>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-error">
        @Model.ErrorMessage
    </div>
}

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">
        @Model.SuccessMessage
    </div>
}

@if (Model.Phases.Count == 0)
{
    <div class="empty-state">
        <div class="empty-state-icon">📋</div>
        <h3>No Phases Found</h3>
        <p>There are no phases defined in the roadmap yet.</p>
        <a href="~/Roadmap" class="btn btn-primary">Manage Phases in Roadmap</a>
    </div>
}
else
{
    <div class="filter-bar">
        <form method="get" class="filter-group">
            <label class="filter-label">Status:</label>
            <select name="FilterStatus" class="filter-select" onchange="this.form.submit()">
                <option value="">All Statuses</option>
                <option value="Draft" selected="@(Model.FilterStatus == "Draft" ? "selected" : null)">Draft</option>
                <option value="Planned" selected="@(Model.FilterStatus == "Planned" ? "selected" : null)">Planned</option>
                <option value="InProgress" selected="@(Model.FilterStatus == "InProgress" ? "selected" : null)">In Progress</option>
                <option value="Blocked" selected="@(Model.FilterStatus == "Blocked" ? "selected" : null)">Blocked</option>
                <option value="Completed" selected="@(Model.FilterStatus == "Completed" ? "selected" : null)">Completed</option>
            </select>
        </form>

        <form method="get" class="filter-group">
            <label class="filter-label">Milestone:</label>
            <select name="FilterMilestoneId" class="filter-select" onchange="this.form.submit()">
                <option value="">All Milestones</option>
                @foreach (var milestone in Model.Phases.Select(p => new { p.MilestoneId, p.MilestoneName }).Distinct())
                {
                    <option value="@milestone.MilestoneId" selected="@(Model.FilterMilestoneId == milestone.MilestoneId ? "selected" : null)">@milestone.MilestoneName</option>
                }
            </select>
        </form>

        <form method="get" class="filter-group" style="flex: 1;">
            <div class="input-group">
                <input type="text" name="SearchQuery" class="form-control" 
                       placeholder="Search phases..." value="@Model.SearchQuery" />
                <button type="submit" class="btn btn-secondary">Search</button>
                @if (!string.IsNullOrEmpty(Model.SearchQuery) || !string.IsNullOrEmpty(Model.FilterStatus) || !string.IsNullOrEmpty(Model.FilterMilestoneId))
                {
                    <a href="~/Phases" class="btn btn-secondary">Clear</a>
                }
            </div>
        </form>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Phase</th>
                <th>Milestone</th>
                <th>Status</th>
                <th>Goals</th>
                <th>Assumptions</th>
                <th>Constraints</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var phase in Model.Phases)
            {
                <tr>
                    <td>
                        <strong>@phase.Name</strong>
                        @if (!string.IsNullOrEmpty(phase.Description))
                        {
                            <br /><small class="text-muted">@phase.Description</small>
                        }
                    </td>
                    <td>@phase.MilestoneName</td>
                    <td>
                        <span class="badge @(phase.Status switch {
                            SpecItemStatus.Completed or SpecItemStatus.Verified => "badge-success",
                            SpecItemStatus.InProgress => "badge-warning",
                            SpecItemStatus.Blocked => "badge-error",
                            SpecItemStatus.Draft => "badge-info",
                            _ => "badge-info"
                        })">
                            @phase.Status
                        </span>
                    </td>
                    <td>@phase.Goals.Count</td>
                    <td>@phase.Assumptions.Count</td>
                    <td>
                        @if (phase.Constraints.Any(c => c.IsBlocking))
                        {
                            <span class="badge badge-error">@phase.Constraints.Count(c => c.IsBlocking) Blocking</span>
                        }
                        else if (phase.Constraints.Any())
                        {
                            <span class="badge badge-warning">@phase.Constraints.Count</span>
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td>
                        <a href="~/Phases/Details/@phase.Id" class="btn btn-sm btn-secondary">View</a>
                        <a href="~/Tasks?phaseId=@phase.Id" class="btn btn-sm btn-primary">Tasks</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="mt-3">
        <a href="~/Roadmap" class="btn btn-secondary">← Back to Roadmap</a>
    </div>
}
