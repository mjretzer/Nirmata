@page
@model Gmsd.Web.Pages.Fix.IndexModel
@{
    ViewData["Title"] = "Fix Planning";
}

<h1>Fix Planning</h1>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-error">
        @Model.ErrorMessage
    </div>
}

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">
        @Model.SuccessMessage
    </div>
}

@if (string.IsNullOrEmpty(Model.WorkspacePath))
{
    <div class="empty-state">
        <div class="empty-state-icon">🔧</div>
        <h3>No Workspace Selected</h3>
        <p>Please select a workspace to view fix plans.</p>
        <a href="~/Workspace" class="btn btn-primary">Select Workspace</a>
    </div>
}
else if (Model.RepairLoops.Count == 0)
{
    <div class="empty-state">
        <div class="empty-state-icon">🔧</div>
        <h3>No Repair Loops</h3>
        <p>There are no active repair loops in this workspace.</p>
        <p class="text-muted">Repair loops are created when issues are routed to fix planning.</p>
        <a href="~/Issues" class="btn btn-secondary">View Issues</a>
    </div>
}
else
{
    <div class="filter-bar">
        <form method="get" class="filter-group">
            <label class="filter-label">Status:</label>
            <select name="FilterStatus" class="filter-select" onchange="this.form.submit()">
                <option value="">All Statuses</option>
                <option value="Active" selected="@(Model.FilterStatus == "Active" ? "selected" : null)">Active</option>
                <option value="Planning" selected="@(Model.FilterStatus == "Planning" ? "selected" : null)">Planning</option>
                <option value="Executing" selected="@(Model.FilterStatus == "Executing" ? "selected" : null)">Executing</option>
                <option value="Verifying" selected="@(Model.FilterStatus == "Verifying" ? "selected" : null)">Verifying</option>
                <option value="Completed" selected="@(Model.FilterStatus == "Completed" ? "selected" : null)">Completed</option>
                <option value="Failed" selected="@(Model.FilterStatus == "Failed" ? "selected" : null)">Failed</option>
            </select>
        </form>

        <form method="get" class="filter-group" style="flex: 1;">
            <div class="input-group">
                <input type="text" name="SearchQuery" class="form-control"
                       placeholder="Search repair loops..." value="@Model.SearchQuery" />
                <button type="submit" class="btn btn-secondary">Search</button>
                @if (!string.IsNullOrEmpty(Model.SearchQuery) || !string.IsNullOrEmpty(Model.FilterStatus))
                {
                    <a href="~/Fix" class="btn btn-secondary">Clear</a>
                }
            </div>
        </form>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Issue</th>
                <th>Status</th>
                <th>Iteration</th>
                <th>Created</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var loop in Model.RepairLoops)
            {
                <tr>
                    <td><code>@loop.Id</code></td>
                    <td>
                        <strong>@loop.IssueTitle</strong>
                        @if (!string.IsNullOrEmpty(loop.IssueId))
                        {
                            <br /><small class="text-muted">Issue: @loop.IssueId</small>
                        }
                    </td>
                    <td>
                        <span class="badge badge-@GetStatusClass(loop.Status)">
                            @loop.Status
                        </span>
                    </td>
                    <td>@loop.CurrentIteration / @loop.MaxIterations</td>
                    <td>
                        @if (loop.CreatedAt.HasValue)
                        {
                            @loop.CreatedAt.Value.ToString("yyyy-MM-dd HH:mm")
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td>
                        <a href="~/Fix/Details/@loop.Id" class="btn btn-sm btn-primary">View</a>
                        @if (!string.IsNullOrEmpty(loop.IssueId))
                        {
                            <a href="~/Issues/Details/@loop.IssueId" class="btn btn-sm btn-secondary">Issue</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="mt-3">
        <a href="~/Issues" class="btn btn-secondary">← Back to Issues</a>
        <a href="~/Runs" class="btn btn-secondary">View Runs</a>
    </div>
}

@functions {
    string GetStatusClass(string? status) => status?.ToLower() switch
    {
        "active" => "info",
        "planning" => "secondary",
        "executing" => "primary",
        "verifying" => "warning",
        "completed" => "success",
        "failed" => "danger",
        _ => "secondary"
    };
}
