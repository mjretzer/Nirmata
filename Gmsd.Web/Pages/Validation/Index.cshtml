@page
@model Gmsd.Web.Pages.Validation.IndexModel
@{
    ViewData["Title"] = "Validation & Maintenance";
}

<h1>Validation & Maintenance</h1>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-error">
        @Model.ErrorMessage
    </div>
}

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">
        @Model.SuccessMessage
    </div>
}

@if (string.IsNullOrEmpty(Model.WorkspacePath))
{
    <div class="empty-state">
        <div class="empty-state-icon">📁</div>
        <h3>No Workspace Selected</h3>
        <p>Please select a workspace to run validations and maintenance operations.</p>
        <a href="~/Workspace" class="btn btn-primary">Select Workspace</a>
    </div>
}
else
{
    <!-- Validation Actions -->
    <div class="dashboard-card mb-4">
        <div class="dashboard-header">
            <h2>Validation Actions</h2>
        </div>
        <div class="dashboard-body">
            <div class="validation-buttons">
                <form method="post" asp-page-handler="ValidateAll" class="d-inline">
                    <button type="submit" class="btn btn-primary">
                        <span class="btn-icon">✓</span> Validate All
                    </button>
                </form>
                <form method="post" asp-page-handler="ValidateSchemas" class="d-inline">
                    <button type="submit" class="btn btn-secondary @GetActiveClass(Model.ActiveValidation, "schemas")">
                        <span class="btn-icon">📋</span> Schemas
                    </button>
                </form>
                <form method="post" asp-page-handler="ValidateSpec" class="d-inline">
                    <button type="submit" class="btn btn-secondary @GetActiveClass(Model.ActiveValidation, "spec")">
                        <span class="btn-icon">📄</span> Spec
                    </button>
                </form>
                <form method="post" asp-page-handler="ValidateState" class="d-inline">
                    <button type="submit" class="btn btn-secondary @GetActiveClass(Model.ActiveValidation, "state")">
                        <span class="btn-icon">💾</span> State
                    </button>
                </form>
                <form method="post" asp-page-handler="ValidateEvidence" class="d-inline">
                    <button type="submit" class="btn btn-secondary @GetActiveClass(Model.ActiveValidation, "evidence")">
                        <span class="btn-icon">📝</span> Evidence
                    </button>
                </form>
                <form method="post" asp-page-handler="ValidateCodebase" class="d-inline">
                    <button type="submit" class="btn btn-secondary @GetActiveClass(Model.ActiveValidation, "codebase")">
                        <span class="btn-icon">🏗️</span> Codebase
                    </button>
                </form>
            </div>

            @if (Model.HasValidationResults)
            {
                <div class="validation-summary mt-3">
                    <strong>Results:</strong> @Model.TotalValidations validation(s) run, @Model.TotalIssues issue(s) found.
                </div>
            }
        </div>
    </div>

    <!-- Maintenance Actions -->
    <div class="dashboard-card mb-4">
        <div class="dashboard-header">
            <h2>Maintenance Actions</h2>
        </div>
        <div class="dashboard-body">
            <div class="maintenance-grid">
                <div class="maintenance-item">
                    <h4>🔧 Repair Indexes</h4>
                    <p class="text-muted">Fix missing or corrupted index files in spec and evidence directories.</p>
                    <form method="post" asp-page-handler="RepairIndexes">
                        <button type="submit" class="btn btn-warning">Repair Indexes</button>
                    </form>
                </div>

                <div class="maintenance-item">
                    <h4>🗑️ Cache Management</h4>
                    <p class="text-muted">Clear or prune stale cache entries.</p>
                    <div class="cache-actions">
                        <form method="post" asp-page-handler="ClearCache" class="d-inline">
                            <button type="submit" class="btn btn-danger" onclick="return confirm('Clear all cache entries?')">
                                Clear Cache
                            </button>
                        </form>
                        <form method="post" asp-page-handler="PruneCache" class="d-inline ml-2">
                            <button type="submit" class="btn btn-secondary">
                                Prune Stale (>7d)
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            @if (Model.CacheStats != null)
            {
                <div class="cache-stats mt-3">
                    <h5>Cache Statistics</h5>
                    @if (Model.CacheStats.Exists)
                    {
                        <div class="stats-grid">
                            <div class="stat-item">
                                <span class="stat-value">@Model.CacheStats.FileCount</span>
                                <span class="stat-label">Files</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-value">@Model.CacheStats.DirectoryCount</span>
                                <span class="stat-label">Directories</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-value">@Model.CacheStats.FormattedSize</span>
                                <span class="stat-label">Total Size</span>
                            </div>
                        </div>
                        <small class="text-muted">Location: <code>@Model.CacheStats.Path</code></small>
                    }
                    else
                    {
                        <p class="text-muted">Cache directory does not exist.</p>
                    }
                </div>
            }
        </div>
    </div>

    <!-- Validation Results -->
    @if (Model.HasValidationResults)
    {
        <div class="dashboard-card mb-4">
            <div class="dashboard-header">
                <h2>Validation Results</h2>
            </div>
            <div class="dashboard-body">
                <div class="validation-results">
                    @foreach (var result in Model.ValidationResults)
                    {
                        <div class="validation-result @GetValidationResultClass(result.Status)">
                            <div class="result-header" onclick="toggleSection('result-@result.Name')">
                                <div class="result-title">
                                    <span class="result-status-icon">@GetStatusIcon(result.Status)</span>
                                    <strong>@result.Name</strong>
                                    <span class="badge @GetStatusBadgeClass(result.Status)">@result.Status</span>
                                </div>
                                <div class="result-meta">
                                    <span class="result-details">@result.Details</span>
                                    <span class="result-issues-count @GetIssuesCountClass(result.Issues.Count)">
                                        @result.Issues.Count issue(s)
                                    </span>
                                    <span class="toggle-icon">▼</span>
                                </div>
                            </div>
                            <div id="result-@result.Name" class="result-body" style="display: none;">
                                <p class="result-description">@result.Description</p>

                                @if (result.Issues.Count > 0)
                                {
                                    <div class="issues-list">
                                        @foreach (var issue in result.Issues)
                                        {
                                            <div class="issue-item @GetIssueSeverityClass(issue.Severity)">
                                                <div class="issue-severity">
                                                    <span class="badge @GetSeverityBadgeClass(issue.Severity)">@issue.Severity</span>
                                                </div>
                                                <div class="issue-content">
                                                    <div class="issue-message">@issue.Message</div>
                                                    <div class="issue-path">
                                                        <a href="~/Workspace?path=@System.Web.HttpUtility.UrlEncode(issue.FilePath)" class="file-link">
                                                            <code>@issue.FilePath</code>
                                                        </a>
                                                        @if (!string.IsNullOrEmpty(issue.Layer))
                                                        {
                                                            <span class="badge badge-small badge-info">@issue.Layer</span>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="no-issues">
                                        <span class="text-success">✓ No issues found</span>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <div class="mt-3">
        <a href="~/" class="btn btn-secondary">← Back to Dashboard</a>
    </div>
}

@functions {
    string GetActiveClass(string? active, string button) => active == button ? "btn-active" : "";

    string GetValidationResultClass(string status) => status switch
    {
        "passed" => "result-passed",
        "warning" => "result-warning",
        "failed" => "result-failed",
        _ => "result-pending"
    };

    string GetStatusBadgeClass(string status) => status switch
    {
        "passed" => "badge-success",
        "warning" => "badge-warning",
        "failed" => "badge-danger",
        _ => "badge-secondary"
    };

    string GetStatusIcon(string status) => status switch
    {
        "passed" => "✓",
        "warning" => "⚠️",
        "failed" => "✗",
        _ => "○"
    };

    string GetIssuesCountClass(int count) => count == 0 ? "issues-none" : (count > 5 ? "issues-many" : "issues-some");

    string GetIssueSeverityClass(string severity) => severity switch
    {
        "error" => "issue-error",
        "warning" => "issue-warning",
        _ => "issue-info"
    };

    string GetSeverityBadgeClass(string severity) => severity switch
    {
        "error" => "badge-danger",
        "warning" => "badge-warning",
        _ => "badge-secondary"
    };
}

<style>
    .validation-buttons {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .validation-buttons form {
        display: inline;
    }

    .btn-active {
        box-shadow: 0 0 0 3px rgba(0, 123, 255, 0.5);
    }

    .validation-summary {
        padding: 0.75rem;
        background: var(--info-bg, #f8f9fa);
        border-radius: 4px;
        border: 1px solid var(--border-color, #e1e4e8);
    }

    .maintenance-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1rem;
    }

    .maintenance-item {
        border: 1px solid var(--border-color, #e1e4e8);
        border-radius: 6px;
        padding: 1rem;
    }

    .maintenance-item h4 {
        margin-top: 0;
        margin-bottom: 0.5rem;
    }

    .cache-actions {
        display: flex;
        gap: 0.5rem;
    }

    .cache-stats {
        background: var(--info-bg, #f8f9fa);
        padding: 0.75rem;
        border-radius: 4px;
        border: 1px solid var(--border-color, #e1e4e8);
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
        margin-bottom: 0.5rem;
    }

    .stat-item {
        text-align: center;
    }

    .stat-value {
        display: block;
        font-size: 1.5rem;
        font-weight: bold;
    }

    .stat-label {
        font-size: 0.875rem;
        color: var(--text-muted, #6c757d);
    }

    .validation-results {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .validation-result {
        border: 1px solid var(--border-color, #e1e4e8);
        border-radius: 6px;
        overflow: hidden;
    }

    .validation-result.result-passed {
        border-left: 4px solid #28a745;
    }

    .validation-result.result-warning {
        border-left: 4px solid #ffc107;
    }

    .validation-result.result-failed {
        border-left: 4px solid #dc3545;
    }

    .validation-result.result-pending {
        border-left: 4px solid #6c757d;
    }

    .result-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.75rem 1rem;
        background: var(--header-bg, #f6f8fa);
        cursor: pointer;
        user-select: none;
    }

    .result-header:hover {
        background: var(--hover-bg, #e9ecef);
    }

    .result-title {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .result-status-icon {
        font-weight: bold;
    }

    .result-meta {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .result-details {
        font-size: 0.875rem;
        color: var(--text-muted, #6c757d);
    }

    .result-issues-count {
        font-size: 0.875rem;
        font-weight: 600;
    }

    .issues-none {
        color: #28a745;
    }

    .issues-some {
        color: #ffc107;
    }

    .issues-many {
        color: #dc3545;
    }

    .toggle-icon {
        font-size: 0.75rem;
        color: var(--text-muted, #6c757d);
    }

    .result-body {
        padding: 1rem;
        border-top: 1px solid var(--border-color, #e1e4e8);
    }

    .result-description {
        color: var(--text-muted, #6c757d);
        margin-top: 0;
        margin-bottom: 1rem;
    }

    .issues-list {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .issue-item {
        display: flex;
        gap: 0.75rem;
        padding: 0.5rem;
        border-radius: 4px;
        background: var(--info-bg, #f8f9fa);
    }

    .issue-error {
        background: #f8d7da;
        border: 1px solid #f5c6cb;
    }

    .issue-warning {
        background: #fff3cd;
        border: 1px solid #ffeeba;
    }

    .issue-severity {
        flex-shrink: 0;
    }

    .issue-content {
        flex: 1;
    }

    .issue-message {
        font-weight: 500;
    }

    .issue-path {
        margin-top: 0.25rem;
        font-size: 0.875rem;
    }

    .file-link {
        color: #0366d6;
        text-decoration: none;
    }

    .file-link:hover {
        text-decoration: underline;
    }

    .file-link code {
        background: rgba(27, 31, 35, 0.05);
        padding: 0.2rem 0.4rem;
        border-radius: 3px;
        font-size: 0.85rem;
    }

    .no-issues {
        padding: 1rem;
        text-align: center;
    }

    .badge-small {
        font-size: 0.7rem;
        padding: 0.15rem 0.4rem;
    }

    .badge-info {
        background: #17a2b8;
        color: white;
    }

    .text-success {
        color: #28a745;
    }

    .d-inline {
        display: inline;
    }

    .ml-2 {
        margin-left: 0.5rem;
    }

    .mt-3 {
        margin-top: 0.75rem;
    }

    .mb-4 {
        margin-bottom: 1rem;
    }
</style>

<script>
    function toggleSection(id) {
        const element = document.getElementById(id);
        if (element.style.display === 'none') {
            element.style.display = 'block';
        } else {
            element.style.display = 'none';
        }
    }
</script>
