@{
    // No server-side active nav - handled by JavaScript
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GMSD</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script src="https://unpkg.com/htmx.org@1.9.10" integrity="sha384-D1Kt99CQMDuVetoL1lrYwg5t+9QdHe7PPXtAQG8x6AiKRp5OQo5D5z5L5z5L5z5L5" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-tomorrow.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/prism.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-json.min.js"></script>
</head>
<body>
    <div class="app-container">
        <!-- Top Bar -->
        <header class="top-bar">
            <div class="top-bar-brand">
                <a href="~/" class="brand-link">GMSD</a>
                <partial name="_WorkspaceBadge" />
            </div>
            <div class="top-bar-actions">
                <!-- Future: user menu, settings, notifications -->
            </div>
        </header>

        <!-- Sidebar Navigation -->
        <aside class="sidebar">
            <nav class="sidebar-nav">
                <!-- Core Section -->
                <div class="nav-section">
                    <div class="nav-section-title">Core</div>
                    <ul class="nav-list">
                        <li class="nav-item">
                            <a class="nav-link" href="~/">
                                <span class="nav-icon">dashboard</span>
                                <span class="nav-text">Dashboard</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="~/Workspace">
                                <span class="nav-icon">folder</span>
                                <span class="nav-text">Workspace</span>
                            </a>
                        </li>
                    </ul>
                </div>

                <!-- Project Management Section -->
                <div class="nav-section">
                    <div class="nav-section-title">Planning</div>
                    <ul class="nav-list">
                        <li class="nav-item">
                            <a class="nav-link" href="~/Roadmap">
                                <span class="nav-icon">map</span>
                                <span class="nav-text">Roadmap</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="~/Projects">
                                <span class="nav-icon">inventory</span>
                                <span class="nav-text">Projects</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="~/Milestones">
                                <span class="nav-icon">flag</span>
                                <span class="nav-text">Milestones</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="~/Phases">
                                <span class="nav-icon">view_timeline</span>
                                <span class="nav-text">Phases</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="~/Tasks">
                                <span class="nav-icon">task_alt</span>
                                <span class="nav-text">Tasks</span>
                            </a>
                        </li>
                    </ul>
                </div>

                <!-- Development Section -->
                <div class="nav-section">
                    <div class="nav-section-title">Development</div>
                    <ul class="nav-list">
                        <li class="nav-item">
                            <a class="nav-link" href="~/Runs">
                                <span class="nav-icon">play_circle</span>
                                <span class="nav-text">Runs</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="~/Specs">
                                <span class="nav-icon">description</span>
                                <span class="nav-text">Specs</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="~/Orchestrator">
                                <span class="nav-icon">terminal</span>
                                <span class="nav-text">Orchestrator</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="~/Codebase">
                                <span class="nav-icon">code</span>
                                <span class="nav-text">Codebase</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="~/Context">
                                <span class="nav-icon">psychology</span>
                                <span class="nav-text">Context</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="~/State">
                                <span class="nav-icon">storage</span>
                                <span class="nav-text">State</span>
                            </a>
                        </li>
                    </ul>
                </div>

                <!-- Quality Section -->
                <div class="nav-section">
                    <div class="nav-section-title">Quality</div>
                    <ul class="nav-list">
                        <li class="nav-item">
                            <a class="nav-link" href="~/Uat">
                                <span class="nav-icon">verified</span>
                                <span class="nav-text">UAT</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="~/Issues">
                                <span class="nav-icon">bug_report</span>
                                <span class="nav-text">Issues</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="~/Fix">
                                <span class="nav-icon">build</span>
                                <span class="nav-text">Fix</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="~/Validation">
                                <span class="nav-icon">check_circle</span>
                                <span class="nav-text">Validation</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="~/Checkpoints">
                                <span class="nav-icon">backup</span>
                                <span class="nav-text">Checkpoints</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </nav>
        </aside>

        <!-- Main Content Area -->
        <main class="main-content" hx-on::after-request="setTimeout(setActiveNav, 50)" hx-on::after-settle="setTimeout(setActiveNav, 50)">
            @RenderBody()
        </main>
    </div>

    <div id="toast-container" class="toast-container"></div>

    @{
        var toastJson = Gmsd.Web.Helpers.ToastHelper.GetToastsJson(this.Model);
    }
    <script>
        window.GmsdServerToasts = @Html.Raw(toastJson);
    </script>

    <script src="~/js/command-palette.js" asp-append-version="true"></script>
    <script src="~/js/artifact-links.js" asp-append-version="true"></script>
    <script src="~/js/toasts.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
