@model Gmsd.Web.Models.SpecItemStatus

@{
    var (cssClass, label) = Model switch
    {
        Gmsd.Web.Models.SpecItemStatus.Draft => ("badge badge-secondary", "Draft"),
        Gmsd.Web.Models.SpecItemStatus.Planned => ("badge badge-info", "Planned"),
        Gmsd.Web.Models.SpecItemStatus.InProgress => ("badge badge-primary", "In Progress"),
        Gmsd.Web.Models.SpecItemStatus.Blocked => ("badge badge-warning", "Blocked"),
        Gmsd.Web.Models.SpecItemStatus.Completed => ("badge badge-success", "Completed"),
        Gmsd.Web.Models.SpecItemStatus.Verified => ("badge badge-success", "Verified"),
        Gmsd.Web.Models.SpecItemStatus.Failed => ("badge badge-error", "Failed"),
        _ => ("badge badge-secondary", "Unknown")
    };
}

<span class="@cssClass">@label</span>
