@model Gmsd.Web.Models.JsonViewerModel

<div class="json-viewer">
    @if (Model.ShowToolbar)
    {
        <div class="json-viewer-toolbar">
            <button type="button" class="btn btn-sm btn-secondary" onclick="copyToClipboard(this)" data-content="@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(Model.JsonContent))">
                <span class="btn-icon">📋</span> Copy
            </button>
            @if (Model.AllowDownload)
            {
                <a href="@Model.DownloadUrl" class="btn btn-sm btn-secondary" download="@Model.FileName">
                    <span class="btn-icon">⬇️</span> Download
                </a>
            }
            <button type="button" class="btn btn-sm btn-secondary" onclick="toggleFormat(this)">
                <span class="btn-icon">🔄</span> Toggle Format
            </button>
        </div>
    }
    <div class="json-viewer-content">
        @if (Model.IsValidJson)
        {
            <pre class="language-json"><code>@Model.FormattedJson</code></pre>
        }
        else
        {
            <pre class="language-text"><code>@Model.JsonContent</code></pre>
        }
    </div>
</div>

<script>
    function copyToClipboard(button) {
        const content = button.getAttribute('data-content');
        navigator.clipboard.writeText(content).then(() => {
            const originalText = button.innerHTML;
            button.innerHTML = '<span class="btn-icon">✅</span> Copied!';
            setTimeout(() => {
                button.innerHTML = originalText;
            }, 2000);
        });
    }

    function toggleFormat(button) {
        const viewer = button.closest('.json-viewer');
        const codeBlock = viewer.querySelector('code');
        const currentContent = codeBlock.textContent;
        
        try {
            const jsonObj = JSON.parse(currentContent);
            const formatted = JSON.stringify(jsonObj, null, 2);
            const minified = JSON.stringify(jsonObj);
            
            if (currentContent === minified) {
                codeBlock.textContent = formatted;
            } else {
                codeBlock.textContent = minified;
            }
            
            // Re-highlight
            if (window.Prism) {
                Prism.highlightElement(codeBlock);
            }
        } catch (e) {
            console.error('Failed to toggle format:', e);
        }
    }
</script>
