@model Gmsd.Web.Models.ValidationReportModel

<div class="validation-report @Model.GetStatusClass()">
    <div class="validation-report-header">
        <div class="validation-status">
            @if (Model.IsValid)
            {
                <span class="status-icon">✅</span>
                <span class="status-text">Validation Passed</span>
            }
            else
            {
                <span class="status-icon">❌</span>
                <span class="status-text">Validation Failed</span>
            }
        </div>
        @if (Model.Errors.Any())
        {
            <div class="error-count">
                @Model.Errors.Count issue@(Model.Errors.Count == 1 ? "" : "s") found
            </div>
        }
    </div>
    
    @if (Model.Errors.Any())
    {
        <div class="validation-errors">
            @foreach (var error in Model.Errors)
            {
                <div class="validation-error-item">
                    <div class="error-location">
                        @if (!string.IsNullOrEmpty(error.Path))
                        {
                            <code class="error-path">@error.Path</code>
                        }
                    </div>
                    <div class="error-message">@error.Message</div>
                    @if (!string.IsNullOrEmpty(error.Suggestion))
                    {
                        <div class="error-suggestion">
                            <span class="suggestion-label">💡 Suggestion:</span> @error.Suggestion
                        </div>
                    }
                </div>
            }
        </div>
    }
    
    @if (Model.Warnings.Any())
    {
        <div class="validation-warnings">
            <div class="warnings-header">
                <span class="warning-icon">⚠️</span>
                @Model.Warnings.Count warning@(Model.Warnings.Count == 1 ? "" : "s")
            </div>
            @foreach (var warning in Model.Warnings)
            {
                <div class="validation-warning-item">
                    @if (!string.IsNullOrEmpty(warning.Path))
                    {
                        <code class="warning-path">@warning.Path</code>
                    }
                    <span class="warning-message">@warning.Message</span>
                </div>
            }
        </div>
    }
    
    @if (Model.SchemaName != null)
    {
        <div class="validation-schema-info">
            Validated against schema: <code>@Model.SchemaName</code>
        </div>
    }
</div>
