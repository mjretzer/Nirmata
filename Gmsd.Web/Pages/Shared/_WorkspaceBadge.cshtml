@using System.Text.Json
@using System.IO
@{
    // Load workspace configuration
    var appData = Environment.GetFolderPath(Environment.SpecialFolder.LocalApplicationData);
    var configPath = System.IO.Path.Combine(System.IO.Path.Combine(appData, "Gmsd"), "workspace-config.json");
    
    string? workspacePath = null;
    var healthStatus = "missing";
    var healthDetails = "";

    if (File.Exists(configPath))
    {
        try
        {
            var json = File.ReadAllText(configPath);
            using var doc = JsonDocument.Parse(json);
            if (doc.RootElement.TryGetProperty("selectedWorkspacePath", out var pathProp))
            {
                workspacePath = pathProp.GetString();
            }
        }
        catch
        {
            // Config file invalid, treat as missing workspace
        }
    }

    // Perform health check on .aos directory
    if (!string.IsNullOrEmpty(workspacePath) && Directory.Exists(workspacePath))
    {
        var aosPath = System.IO.Path.Combine(workspacePath, ".aos");
        
        if (File.Exists(aosPath))
        {
            healthStatus = "invalid"; // .aos exists as file, not directory
            healthDetails = ".aos is a file (should be directory)";
        }
        else if (Directory.Exists(aosPath))
        {
            // Basic validation: check for essential subdirectories
            var requiredDirs = new[] { "spec", "state", "evidence" };
            var missingDirs = requiredDirs.Where(d => !Directory.Exists(System.IO.Path.Combine(aosPath, d))).ToList();
            
            if (missingDirs.Any())
            {
                healthStatus = "invalid";
                healthDetails = $"Missing: {string.Join(", ", missingDirs)}";
            }
            else
            {
                healthStatus = "valid";
                healthDetails = "Workspace healthy";
            }
        }
        else
        {
            healthStatus = "missing";
            healthDetails = ".aos directory not found";
        }
    }
    else
    {
        healthStatus = "missing";
        healthDetails = "No workspace selected";
    }

    // Determine indicator styles
    var (indicatorClass, icon) = healthStatus switch
    {
        "valid" => ("health-indicator health-valid", "●"),
        "invalid" => ("health-indicator health-invalid", "●"),
        _ => ("health-indicator health-missing", "○")
    };

    // Format display path (truncate if too long)
    var displayPath = workspacePath ?? "No workspace";
    if (displayPath.Length > 40)
    {
        displayPath = "..." + displayPath[^37..];
    }
}

<div class="workspace-badge" title="@healthDetails&#10;Path: @(workspacePath ?? "Not configured")">
    <span class="repo-icon">📁</span>
    <span class="workspace-path">@displayPath</span>
    <span class="@indicatorClass">@icon</span>
</div>
